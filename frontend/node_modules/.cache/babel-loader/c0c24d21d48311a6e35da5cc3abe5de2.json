{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: \"LogIn\",\n\n  data() {\n    return {\n      username: \"\",\n      password: \"\",\n      emailId: \"\",\n      errors: []\n    };\n  },\n\n  methods: {\n    async submitForm() {\n      axios.defaults.headers.common[\"Authorization\"] = \"\";\n      localStorage.removeItem(\"token\");\n      const formData = {\n        username: this.username,\n        password: this.password\n      };\n      await axios.post(\"/api/v1/token/login/\", formData).then(response => {\n        const token = response.data.auth_token;\n        this.$store.commit('setToken', token);\n        axios.defaults.headers.common[\"Authorization\"] = \"Token \" + token;\n        localStorage.setItem(\"token\", token);\n        const toPath = this.$route.query.to || '/cart';\n        this.$router.push(toPath);\n      }).catch(error => {\n        if (error.response) {\n          for (const property in error.response.data) {\n            this.errors.push(`${property}: ${error.response.data[property]}`);\n          }\n        } else {\n          this.errors.push('Something went wrong. Please try again');\n          console.log(JSON.stringify(error));\n        }\n      });\n    }\n\n  }\n};","map":{"version":3,"mappings":"AA+CA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACXC,IAAI,EAAE,OADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,QAAQ,EAAE,EADP;MAEHC,QAAQ,EAAE,EAFP;MAGHC,OAAO,EAAE,EAHN;MAIHC,MAAM,EAAE;IAJL,CAAP;EAMH,CATU;;EAUXC,OAAO,EAAE;IACL,MAAMC,UAAN,GAAmB;MACfR,KAAK,CAACS,QAAN,CAAeC,OAAf,CAAuBC,MAAvB,CAA8B,eAA9B,IAAiD,EAAjD;MACAC,YAAY,CAACC,UAAb,CAAwB,OAAxB;MACA,MAAMC,QAAO,GAAI;QACbX,QAAQ,EAAE,KAAKA,QADF;QAEbC,QAAQ,EAAE,KAAKA;MAFF,CAAjB;MAIA,MAAMJ,KAAI,CACLe,IADC,CACI,sBADJ,EAC4BD,QAD5B,EAEDE,IAFC,CAEIC,QAAO,IAAK;QACd,MAAMC,KAAI,GAAID,QAAQ,CAACf,IAAT,CAAciB,UAA5B;QACA,KAAKC,MAAL,CAAYC,MAAZ,CAAmB,UAAnB,EAA+BH,KAA/B;QAEAlB,KAAK,CAACS,QAAN,CAAeC,OAAf,CAAuBC,MAAvB,CAA8B,eAA9B,IAAiD,WAAWO,KAA5D;QACAN,YAAY,CAACU,OAAb,CAAqB,OAArB,EAA8BJ,KAA9B;QACA,M