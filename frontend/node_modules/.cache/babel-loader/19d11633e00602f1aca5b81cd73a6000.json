{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'HomeView',\n\n  data() {\n    return {\n      latestProducts: []\n    };\n  },\n\n  components: {},\n\n  mounted() {\n    this.getLatestProducts();\n  },\n\n  methods: {\n    async getLatestProducts() {\n      this.$store.commit('setIsLoading', true);\n      await axios.get(\"/api/v1/latest-products/\").then(response => {\n        this.latestProducts = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAqCA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACbC,IAAI,EAAE,UADO;;EAEbC,IAAI,GAAG;IACL,OAAO;MACLC,cAAc,EAAE;IADX,CAAP;EAGD,CANY;;EAObC,UAAU,EAAE,EAPC;;EASbC,OAAO,GAAG;IACR,KAAKC,iBAAL;EACD,CAXY;;EAYbC,OAAO,EAAE;IACP,MAAMD,iBAAN,GAA0B;MACxB,KAAKE,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,IAAnC;MACA,MAAMT,KAAI,CACPU,GADG,CACC,0BADD,EAEHC,IAFG,CAEEC,QAAO,IAAK;QAChB,KAAKT,cAAL,GAAsBS,QAAQ,CAACV,IAA/B;MACD,CAJG,EAKHW,KALG,CAKGC,KAAI,IAAK;QACdC,OAAO,CAACC,GAAR,CAAYF,KAAZ;MACD,CAPG,CAAN;MAQA,KAAKN,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,KAAnC;IACF;;EAZO;AAZI,CAAf","names":["axios","name","data","latestProducts","components","mounted","getLatestProducts","methods","$store","commit","get","then","response","catch","error","console","log"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/HomeView.vue"],"sourcesContent":["<template>\n  <div class=\"home\">\n    <section class=\"hero is-small is-dark mb-6\">\n      <div class=\"hero-body has-text-centered\">\n        <p class=\"title mb-6\">\n          Welcome to Bookish\n        </p>\n        <p class=\"subtitle\">\n          A demo E-commerce website for shopping books\n        </p>\n      </div>\n    </section>\n\n    <div class=\"columns is-multiline\">\n      <div class=\"column is-12\">\n        <h2 class=\"is-size-2 has-text-centered\">Latest products</h2>\n      </div>\n    </div>\n\n    <div class=\"columns is-multiline\">\n      <section v-for=\"product in latestProducts\" :key=\"product.id\" class=\"column is-3 section is-small\">\n        <div class=\"box\">\n          <figure class=\"image mb-4\">\n            <img :src=\"product.get_thumbnail\" alt=\"Oops\">\n            <h6 class=\"is-size-5 has-text-weight-bold\">{{ product.name }}</h6>\n            <p class=\"is-size-5 has-text-grey\">₹{{ product.price }}</p>\n            <router-link v-bind:to=\"product.get_absolute_url\" class=\"button is-dark mt-4 center\">View details\n            </router-link>\n          </figure>\n        </div>\n      </section>\n    </div>\n\n  </div>\n</template>\n\n<script>\nimport axios from 'axios';\nexport default {\n  name: 'HomeView',\n  data() {\n    return {\n      latestProducts: [],\n    }\n  },\n  components: {\n  },\n  mounted() {\n    this.getLatestProducts()\n  },\n  methods: {\n    async getLatestProducts() {\n      this.$store.commit('setIsLoading', true)\n      await axios\n        .get(\"/api/v1/latest-products/\")\n        .then(response => {\n          this.latestProducts = response.data\n        })\n        .catch(error => {\n          console.log(error)\n        })\n      this.$store.commit('setIsLoading', false)\n    }\n  }\n}\n</script>\n\n<style scoped>\n.image {\n  margin-top: -1.25rem;\n  margin-left: -1.25rem;\n  margin-right: -1.25rem;\n}\n\n.center {\n  display: block;\n  margin-left: auto;\n  margin-right: auto;\n  width: 50%;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}