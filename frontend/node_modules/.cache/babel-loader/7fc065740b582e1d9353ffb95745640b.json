lass=\"button is-dark\">Add to cart</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</template>\n\n<script>\nimport axios from 'axios';\nexport default {\n    name: 'Product',\n    data() {\n        return {\n            product: {},\n            quantity: 1\n        }\n\n    },\n    mounted() {\n        this.getProduct();\n        console.log(\"HII\");\n        console.log(this.product);\n    },\n    methods: {\n        getProduct() {\n            //const category_slug = this.$route.params.category_slug\n            //const product_slug = this.$route.params.product_slug\n            this.product = \"/api/v1/products/romance/one-indian-girl\"\n        }\n    }\n}\n</script>"]},"metadata":{},"sourceType":"module"}