{"ast":null,"code":"export default {\n  name: \"LogIn\"\n};","map":{"version":3,"mappings":"AA+CA,eAAe;EACXA,IAAI,EAAE;AADK,CAAf","names":["name"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/LogIn.vue"],"sourcesContent":["<template>\n    <div class=\"page-sign-up\">\n        <div class=\"columns\">\n            <div class=\"column is-4 is-offset-4\">\n                <h1 class=\"title\">Sign up</h1>\n\n                <form @submit.prevent=\"submitForm\">\n                    <div class=\"field\">\n                        <label>Username</label>\n                        <div class=\"control\">\n                            <input type=\"text\" class=\"input\" v-model=\"username\">\n                        </div>\n                    </div>\n\n                    <div class=\"field\">\n                        <label>Email Address (Optional)</label>\n                        <div class=\"control\">\n                            <input type=\"email\" class=\"input\" v-model=\"emailId\">\n                        </div>\n                    </div>\n\n                    <div class=\"field\">\n                        <label>Repeat password</label>\n                        <div class=\"control\">\n                            <input type=\"password\" class=\"input\" v-model=\"password2\">\n                        </div>\n                    </div>\n\n                    <div class=\"notification is-danger\" v-if=\"errors.length\">\n                        <p v-for=\"error in errors\" v-bind:key=\"error\">{{ error }}</p>\n                    </div>\n\n                    <div class=\"field\">\n                        <div class=\"control\">\n                            <button class=\"button is-dark\">Sign up</button>\n                        </div>\n                    </div>\n\n                    <hr>\n\n                    Or <router-link to=\"/login\">click here</router-link> to log in!\n                </form>\n            </div>\n        </div>\n    </div>\n</template>\n<script>\nexport default {\n    name: \"LogIn\"\n}\n</script>"]},"metadata":{},"sourceType":"module"}