{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'Search',\n\n  data() {\n    return {\n      products: [],\n      query: '',\n      url: 'http://127.0.0.1:8000/api/v1/products/search/'\n    };\n  },\n\n  mounted() {\n    let post = window.location.search.substring(1);\n    let params = new URLSearchParams(post);\n\n    if (params.get('query')) {\n      this.query = params.get('query');\n      this.performSearch();\n    }\n  },\n\n  methods: {\n    async performSearch() {},\n\n    async performAuto() {\n      this.$store.commit('setIsLoading', true);\n      await axios.post(this.url, {\n        'query': this.query\n      }).then(response => {\n        console.log(response.data);\n        this.products = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    },\n\n    async performAuto() {\n      this.$store.commit('setIsLoading', true);\n      await axios.post(this.url, {\n        'query': this.query\n      }).then(response => {\n        console.log(response.data);\n        this.products = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    }\n\n  }\n};","map":{"version":3,"mappings":"AA0BA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACXC,IAAI,EAAE,QADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,QAAQ,EAAE,EADP;MAEHC,KAAK,EAAE,EAFJ;MAGHC,GAAG,EAAE;IAHF,CAAP;EAKH,CARU;;EASXC,OAAO,GAAG;IACN,IAAIC,IAAG,GAAIC,MAAM,CAACC,QAAP,CAAgBC,MAAhB,CAAuBC,SAAvB,CAAiC,CAAjC,CAAX;IACA,IAAIC,MAAK,GAAI,IAAIC,eAAJ,CAAoBN,IAApB,CAAb;;IACA,IAAIK,MAAM,CAACE,GAAP,CAAW,OAAX,CAAJ,EAAyB;MACrB,KAAKV,KAAL,GAAaQ,MAAM,CAACE,GAAP,CAAW,OAAX,CAAb;MACA,KAAKC,aAAL;IACJ;EACH,CAhBU;;EAiBXC,OAAO,EAAE;IACL,MAAMD,aAAN,GAAsB,CAErB,CAHI;;IAIL,MAAME,WAAN,GAAoB;MAChB,KAAKC,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,IAAnC;MACA,MAAMnB,KAAI,CACLO,IADC,CACI,KAAKF,GADT,EACc;QAAE,SAAS,KAAKD;MAAhB,CADd,EAEDgB,IAFC,CAEIC,QAAO,IAAK;QACdC,OAAO,CAACC,GAAR,CAAYF,