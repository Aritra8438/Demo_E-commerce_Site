{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'Search',\n\n  data() {\n    return {\n      products: [],\n      query: '',\n      url: 'http://127.0.0.1:8000/api/v1/products/search/'\n    };\n  },\n\n  mounted() {\n    let post = window.location.search.substring(1);\n    let params = new URLSearchParams(post);\n\n    if (params.get('query')) {\n      this.query = params.get('query');\n      this.performSearch();\n    }\n  },\n\n  methods: {\n    async performSearch() {\n      this.$store.commit('setIsLoading', true);\n      await axios.post(this.url, {\n        'query': this.query\n      }).then(response => {\n        console.log(response.data);\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAeI,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACXC,IAAI,EAAE,QADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,QAAQ,EAAE,EADP;MAEHC,KAAK,EAAE,EAFJ;MAGHC,GAAG,EAAE;IAHF,CAAP;EAKH,CARU;;EASXC,OAAO,GAAG;IACN,IAAIC,IAAG,GAAIC,MAAM,CAACC,QAAP,CAAgBC,MAAhB,CAAuBC,SAAvB,CAAiC,CAAjC,CAAX;IACA,IAAIC,MAAK,GAAI,IAAIC,eAAJ,CAAoBN,IAApB,CAAb;;IACA,IAAGK,MAAM,CAACE,GAAP,CAAW,OAAX,CAAH,EAAuB;MACnB,KAAKV,KAAL,GAAaQ,MAAM,CAACE,GAAP,CAAW,OAAX,CAAb;MACA,KAAKC,aAAL;IACJ;EACH,CAhBU;;EAiBXC,OAAO,EAAE;IACL,MAAMD,aAAN,GAAqB;MACjB,KAAKE,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,IAAnC;MACA,MAAMlB,KAAI,CACTO,IADK,CACA,KAAKF,GADL,EACS;QAAC,SAAQ,KAAKD;MAAd,CADT,EAELe,IAFK,CAEAC,QAAQ,IAAE;QACZC,OAAO,CAACC,GAAR,CAAYF,QAAQ,CAAClB,IAArB;MACH,CAJK,EAKLqB,KALK,CAKCC,KAAK,IAAE;QACVH,OAAO,CAACC,GAAR,CAAYE,KAAZ;MACH,CAPK,CAAN;MAQA,KAAKP,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,KAAnC;IACJ;;EAZK;AAjBE,CAAf","names":["axios","name","data","products","query","url","mounted","post","window","location","search","substring","params","URLSearchParams","get","performSearch","methods","$store","commit","then","response","console","log","catch","error"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/Search.vue"],"sourcesContent":["<template>\n    <div class=\"page-search\">\n        <div class=\"columns is-multiline\">\n            <div class=\"column is-12\">\n                <h1 class=\"title\">Search</h1>\n\n                <h2 class=\"is-size-5 has-text-grey\">Search term: \"{{ query }}\"</h2>\n            </div>\n\n\n        </div>\n    </div>\n</template>\n\n<script>\n    import axios from 'axios';\n    export default {\n        name: 'Search',\n        data() {\n            return {\n                products: [],                                \n                query: '',\n                url: 'http://127.0.0.1:8000/api/v1/products/search/'\n            }\n        },\n        mounted() {                        \n            let post = window.location.search.substring(1)\n            let params = new URLSearchParams(post)              \n            if(params.get('query')){\n                this.query = params.get('query')\n                this.performSearch()\n            }\n        },\n        methods: {         \n            async performSearch(){\n                this.$store.commit('setIsLoading', true)                \n                await axios\n                .post(this.url,{'query':this.query})                 \n                .then(response=>{                    \n                    console.log(response.data)\n                })\n                .catch(error=>{\n                    console.log(error)\n                })                \n                this.$store.commit('setIsLoading', false)                \n            }            \n        }\n    };\n</script>"]},"metadata":{},"sourceType":"module"}