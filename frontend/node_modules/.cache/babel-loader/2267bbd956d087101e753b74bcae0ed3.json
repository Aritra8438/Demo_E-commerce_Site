{"ast":null,"code":"import axios from 'axios';\nimport { toast } from 'bulma-toast';\nexport default {\n  name: 'Cart',\n\n  data() {\n    return {\n      cart: [],\n      items: []\n    };\n  },\n\n  mounted() {\n    this.cart = this.$store.state.cart;\n  },\n\n  methods: {\n    modifyCartItem(item) {\n      this.$store.commit('modifyCartItem', item);\n      toast({\n        message: 'cart updated',\n        type: 'is-success',\n        dismissible: true,\n        pauseOnHover: true,\n        duration: 2000,\n        position: 'bottom-right'\n      });\n    }\n\n  },\n  computed: {\n    billingPrice() {\n      this.items = this.cart.items;\n      let total = 0;\n\n      for (let j in this.cart.items) {\n        total += this.cart.items[j].quantity * this.cart.items[j].product.price;\n      }\n\n      return total;\n    }\n\n  }\n};","map":{"version":3,"mappings":"AA8BI,OAAOA,KAAP,MAAkB,OAAlB;AACA,SAASC,KAAT,QAAsB,aAAtB;AACA,eAAe;EACXC,IAAI,EAAE,MADK;;EAEXC,IAAI,GAAG;IACH,OAAM;MACFC,IAAI,EAAE,EADJ;MAEFC,KAAK,EAAE;IAFL,CAAN;EAIH,CAPU;;EAQXC,OAAO,GAAG;IACN,KAAKF,IAAL,GAAY,KAAKG,MAAL,CAAYC,KAAZ,CAAkBJ,IAA9B;EACH,CAVU;;EAWXK,OAAO,EAAE;IACLC,cAAc,CAACC,IAAD,EAAM;MAChB,KAAKJ,MAAL,CAAYK,MAAZ,CAAmB,gBAAnB,EAAqCD,IAArC;MAEAV,KAAK,CAAC;QACFY,OAAO,EAAE,cADP;QAEFC,IAAI,EAAE,YAFJ;QAGFC,WAAW,EAAE,IAHX;QAIFC,YAAY,EAAE,IAJZ;QAKFC,QAAQ,EAAE,IALR;QAMFC,QAAQ,EAAE;MANR,CAAD,CAAL;IAQH;;EAZI,CAXE;EAyBXC,QAAQ,EAAE;IACNC,YAAY,GAAG;MACX,KAAKf,KAAL,GAAa,KAAKD,IAAL,CAAUC,KAAvB;MACA,IAAIgB,KAAI,GAAI,CAAZ;;MACA,KAAI,IAAIC,CAAR,IAAa,KAAKlB,IAAL,CAAUC,KAAvB,EAA6B;QACzBgB,KAAI,IAAM,KAAKjB,IAAL,CAAUC,KAAV,CAAgBiB,CAAhB,EAAmBC,QAApB,GAA+B,KAAKnB,IAAL,CAAUC,KAAV,CAAgBiB,CAAhB,EAAmBE,OAAnB,CAA2BC,KAAnE;MACJ;;MACA,OAAOJ,KAAP;IACH;;EARK;AAzBC,CAAf","names":["axios","toast","name","data","cart","items","mounted","$store","state","methods","modifyCartItem","item","commit","message","type","dismissible","pauseOnHover","duration","position","computed","billingPrice","total","j","quantity","product","price"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/Cart.vue"],"sourcesContent":["<template>\n    <h1 class='is-size-2 has-text-primary has-text-weight-medium is-family-sans-serif'> HERE IS YOUR CART WITH\n        SUBTOTAL\n        ₹{{billingPrice}}</h1>\n    <div class=\"columns is-multiline\">\n        <section v-for=\"item in items\" :key=\"item.product.id\" class=\"column is-4 section is-small\">\n            <div class=\"box\">\n                <figure class=\"image mb-4\">\n                    <img :src=\"item.product.get_thumbnail\" alt=\"Oops\">\n                    <h6 class=\"is-size-5 has-text-weight-bold\">{{ item.product.name }}</h6>\n                    <div class=\"field has-addons mt-6\">\n                        <div class=\"control\">\n                            <input type=\"number\" class=\"input\" min=\"1\" v-model=\"item.quantity\">\n                        </div>\n\n                        <div class=\"control\">\n                            <a class=\"button is-dark\" @click=\"modifyCartItem(item)\">Upd</a>\n                        </div>\n                    </div>\n                    <p class=\"is-size-5 has-text-grey\"> subtotal ₹{{ item.product.price*item.quantity }}</p>\n                    <router-link v-bind:to=\"item.product.get_absolute_url\" class=\"button is-dark mt-4 center\">View\n                        details\n                    </router-link>\n                </figure>\n            </div>\n        </section>\n    </div>\n</template>\n\n<script>\n    import axios from 'axios';\n    import { toast } from 'bulma-toast';\n    export default {\n        name: 'Cart',\n        data() {\n            return{\n                cart: [],\n                items: [],\n            }            \n        },\n        mounted() {\n            this.cart = this.$store.state.cart                                    \n        },\n        methods: {\n            modifyCartItem(item){                \n                this.$store.commit('modifyCartItem', item);\n                \n                toast({\n                    message: 'cart updated',\n                    type: 'is-success',\n                    dismissible: true,\n                    pauseOnHover: true,\n                    duration: 2000,\n                    position: 'bottom-right',\n                });\n            },            \n        },\n        computed: {\n            billingPrice() {\n                this.items = this.cart.items;\n                let total = 0;\n                for(let j in this.cart.items){                    \n                    total += (this.cart.items[j].quantity)*(this.cart.items[j].product.price);                    \n                }                \n                return total;\n            },            \n        },        \n    }\n    \n</script>"]},"metadata":{},"sourceType":"module"}