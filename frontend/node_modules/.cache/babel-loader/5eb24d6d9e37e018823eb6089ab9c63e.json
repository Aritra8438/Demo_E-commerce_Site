{"ast":null,"code":"import axios from 'axios';\nimport { toast } from 'bulma-toast';\nexport default {\n  name: 'Product',\n\n  data() {\n    return {\n      product: {},\n      quantity: 1,\n      url: 'api/v1/products/'\n    };\n  },\n\n  mounted() {\n    this.getProduct();\n  },\n\n  methods: {\n    getProduct() {\n      const category_slug = this.$route.params.category_slug;\n      const product_slug = this.$route.params.product_slug;\n      const specific = this.url + category_slug + '/' + product_slug + '/';\n      axios.get(specific).then(response => {\n        this.product = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n\n    addToCart() {\n      const item = {\n        product: this.product,\n        quantity: this.quantity\n      };\n      this.$store.commit('addToCart', item);\n      toast({\n        message: 'The product is added to the cart',\n        type: 'is-success',\n        dismissible: true,\n        pauseOnHover: true,\n        duration: 2000,\n        position: 'bottom-right'\n      });\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAiCA,OAAOA,KAAP,MAAkB,OAAlB;AACA,SAASC,KAAT,QAAsB,aAAtB;AAEA,eAAe;EACXC,IAAI,EAAE,SADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,OAAO,EAAE,EADN;MAEHC,QAAQ,EAAE,CAFP;MAGHC,GAAG,EAAE;IAHF,CAAP;EAMH,CATU;;EAUXC,OAAO,GAAG;IACN,KAAKC,UAAL;EACH,CAZU;;EAaXC,OAAO,EAAE;IACLD,UAAU,GAAG;MACT,MAAME,aAAY,GAAI,KAAKC,MAAL,CAAYC,MAAZ,CAAmBF,aAAzC;MACA,MAAMG,YAAW,GAAI,KAAKF,MAAL,CAAYC,MAAZ,CAAmBC,YAAxC;MACA,MAAMC,QAAO,GAAI,KAAKR,GAAL,GAAWI,aAAX,GAA2B,GAA3B,GAAiCG,YAAjC,GAAgD,GAAjE;MACAb,KAAI,CACCe,GADL,CACSD,QADT,EAEKE,IAFL,CAEUC,QAAO,IAAK;QACd,KAAKb,OAAL,GAAea,QAAQ,CAACd,IAAxB;MACH,CAJL,EAKKe,KALL,CAKWC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAR,CAAYF,KAAZ;MACH,CAPL;IAQH,CAbI;;IAcLG,SAAS,GAAG;MACR,MAAMC,IAAG,GAAI;QACTnB,OAAO,EAAE,KAAKA,OADL;QAETC,QAAQ,EAAE,KAAKA;MAFN,CAAb;MAIA,KAAKmB,MAAL,CAAYC,MAAZ,CAAmB,WAAnB,EAAgCF,IAAhC;MAEAtB,KAAK,CAAC;QACFyB,OAAO,EAAE,kCADP;QAEFC,IAAI,EAAE,YAFJ;QAGFC,WAAW,EAAE,IAHX;QAIFC,YAAY,EAAE,IAJZ;QAKFC,QAAQ,EAAE,IALR;QAMFC,QAAQ,EAAE;MANR,CAAD,CAAL;IAQJ;;EA7BK;AAbE,CAAf","names":["axios","toast","name","data","product","quantity","url","mounted","getProduct","methods","category_slug","$route","params","product_slug","specific","get","then","response","catch","error","console","log","addToCart","item","$store","commit","message","type","dismissible","pauseOnHover","duration","position"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/Product.vue"],"sourcesContent":["<template>\n    <div class=\"page-product\">\n        <div class=\"columns is-multiline\">\n            <div class=\"column is-9\">\n                <figure class=\"image mb-6 center\">\n                    <img v-bind:src=\"product.get_image\">\n                </figure>\n\n                <h1 class=\"title\">{{ product.name }}</h1>\n\n                <p>{{ product.description }}</p>\n            </div>\n\n            <div class=\"column is-3\">\n                <h2 class=\"subtitle\">Information</h2>\n\n                <p><strong>Price: </strong>₹{{ product.price }}</p>\n\n                <div class=\"field has-addons mt-6\">\n                    <div class=\"control\">\n                        <input type=\"number\" class=\"input\" min=\"1\" v-model=\"quantity\">\n                    </div>\n\n                    <div class=\"control\">\n                        <a class=\"button is-dark\" @click=\"addToCart\">Add to cart</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</template>\n\n<script>\nimport axios from 'axios';\nimport { toast } from 'bulma-toast';\n\nexport default {\n    name: 'Product',\n    data() {\n        return {\n            product: {},\n            quantity: 1,\n            url: 'api/v1/products/'\n        }\n\n    },\n    mounted() {\n        this.getProduct();\n    },\n    methods: {\n        getProduct() {\n            const category_slug = this.$route.params.category_slug\n            const product_slug = this.$route.params.product_slug\n            const specific = this.url + category_slug + '/' + product_slug + '/'\n            axios\n                .get(specific)\n                .then(response => {\n                    this.product = response.data\n                })\n                .catch(error => {\n                    console.log(error)\n                })\n        },\n        addToCart() {\n            const item = {\n                product: this.product,\n                quantity: this.quantity,\n            }\n            this.$store.commit('addToCart', item);\n\n            toast({\n                message: 'The product is added to the cart',\n                type: 'is-success',\n                dismissible: true,\n                pauseOnHover: true,\n                duration: 2000,\n                position: 'bottom-right',\n            });\n        }\n    }\n}\n</script>\n\n<style scoped>\n.image {\n    margin-top: -1.25rem;\n    margin-left: -1.25rem;\n    margin-right: -1.25rem;\n    max-width: 200px;\n}\n\n.center {\n    display: block;\n    margin-left: auto;\n    margin-right: auto;\n    width: 50%;\n}\n</style>\n\n\n"]},"metadata":{},"sourceType":"module"}