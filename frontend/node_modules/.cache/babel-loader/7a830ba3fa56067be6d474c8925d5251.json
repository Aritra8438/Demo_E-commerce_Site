{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'category',\n\n  data() {\n    return {\n      products: [],\n      url: \"/api/v1/products/\"\n    };\n  },\n\n  mounted() {\n    this.getProducts();\n  },\n\n  watch: {\n    $route(to, from) {\n      console.log(to);\n\n      if (to.name === 'Category') {\n        this.getProducts();\n      }\n    }\n\n  },\n  methods: {\n    async getProducts() {\n      this.$store.commit('setIsLoading', true);\n      const category_slug = this.$route.params.category_slug;\n      const specific = this.url + category_slug;\n      await axios.get(specific).then(response => {\n        //console.log(response.data)\n        this.products = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAoBA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACXC,IAAI,EAAE,UADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,QAAQ,EAAE,EADP;MAEHC,GAAG,EAAE;IAFF,CAAP;EAIH,CAPU;;EAQXC,OAAO,GAAG;IACN,KAAKC,WAAL;EACH,CAVU;;EAWXC,KAAK,EAAE;IACHC,MAAM,CAACC,EAAD,EAAKC,IAAL,EAAW;MACbC,OAAO,CAACC,GAAR,CAAYH,EAAZ;;MACA,IAAIA,EAAE,CAACR,IAAH,KAAY,UAAhB,EAA4B;QACxB,KAAKK,WAAL;MACJ;IACJ;;EANG,CAXI;EAmBXO,OAAO,EAAE;IACL,MAAMP,WAAN,GAAoB;MAChB,KAAKQ,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,IAAnC;MACA,MAAMC,aAAY,GAAI,KAAKR,MAAL,CAAYS,MAAZ,CAAmBD,aAAzC;MACA,MAAME,QAAO,GAAI,KAAKd,GAAL,GAAWY,aAA5B;MACA,MAAMhB,KAAI,CACLmB,GADC,CACGD,QADH,EAEDE,IAFC,CAEIC,QAAO,IAAK;QACd;QACA,KAAKlB,QAAL,GAAgBkB,QAAQ,CAACnB,IAAzB;MACH,CALC,EAMDoB,KANC,CAMKC,KAAI,IAAK;QACZZ,OAAO,CAACC,GAAR,CAAYW,KAAZ;MACH,CARC,CAAN;MASA,KAAKT,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,KAAnC;IAEJ;;EAhBK;AAnBE,CAAf","names":["axios","name","data","products","url","mounted","getProducts","watch","$route","to","from","console","log","methods","$store","commit","category_slug","params","specific","get","then","response","catch","error"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/Category.vue"],"sourcesContent":["<template>\n    <div class=\"page-category\">\n        <div class=\"columns is-multiline\">\n            <section v-for=\"product in products\" :key=\"product.id\" class=\"column is-3 section is-small\">\n                <div class=\"box\">\n                    <figure class=\"image mb-4\">\n                        <img :src=\"product.get_thumbnail\" alt=\"Oops\">\n                        <h6 class=\"is-size-5 has-text-weight-bold\">{{ product.name }}</h6>\n                        <p class=\"is-size-5 has-text-grey\">₹{{ product.price }}</p>\n                        <router-link v-bind:to=\"product.get_absolute_url\" class=\"button is-dark mt-4 center\">View\n                            details\n                        </router-link>\n                    </figure>\n                </div>\n            </section>\n        </div>\n    </div>\n</template>\n\n<script>\nimport axios from 'axios';\nexport default {\n    name: 'category',\n    data() {\n        return {\n            products: [],\n            url: \"/api/v1/products/\",\n        }\n    },\n    mounted() {\n        this.getProducts()\n    },\n    watch: {\n        $route(to, from) {\n            console.log(to)\n            if (to.name === 'Category') {\n                this.getProducts()\n            }\n        }\n    },\n    methods: {\n        async getProducts() {\n            this.$store.commit('setIsLoading', true)\n            const category_slug = this.$route.params.category_slug;\n            const specific = this.url + category_slug;\n            await axios\n                .get(specific)\n                .then(response => {\n                    //console.log(response.data)\n                    this.products = response.data;\n                })\n                .catch(error => {\n                    console.log(error)\n                })\n            this.$store.commit('setIsLoading', false)\n\n        }\n    }\n}\n</script>"]},"metadata":{},"sourceType":"module"}