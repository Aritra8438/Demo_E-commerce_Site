{"ast":null,"code":"import axios from 'axios';\nimport { URLSearchParams } from 'url';\nexport default {\n  name: 'Search',\n\n  data() {\n    return {\n      products: [],\n      query: '',\n      url: 'http://127.0.0.1:8000/api/v1/products/search/?query='\n    };\n  },\n\n  mounted() {\n    this.getProducts();\n    let post = window.location.search.substring(1);\n    let params = new URLSearchParams(post);\n    console.log(params);\n\n    if (params['query']) {\n      this.query = params['query'];\n    }\n  },\n\n  methods: {\n    getProducts() {\n      this.$store.commit('setIsLoading', true);\n      console.log(\"Seaching\");\n      this.$store.commit('setIsLoading', false);\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAKI,OAAOA,KAAP,MAAkB,OAAlB;AACJ,SAASC,eAAT,QAAgC,KAAhC;AACI,eAAe;EACXC,IAAI,EAAE,QADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,QAAQ,EAAE,EADP;MAEHC,KAAK,EAAE,EAFJ;MAGHC,GAAG,EAAE;IAHF,CAAP;EAKH,CARU;;EASXC,OAAO,GAAG;IACN,KAAKC,WAAL;IACA,IAAIC,IAAG,GAAIC,MAAM,CAACC,QAAP,CAAgBC,MAAhB,CAAuBC,SAAvB,CAAiC,CAAjC,CAAX;IACA,IAAIC,MAAK,GAAI,IAAIb,eAAJ,CAAoBQ,IAApB,CAAb;IACAM,OAAO,CAACC,GAAR,CAAYF,MAAZ;;IACA,IAAGA,MAAM,CAAC,OAAD,CAAT,EAAmB;MACf,KAAKT,KAAL,GAAaS,MAAM,CAAC,OAAD,CAAnB;IACJ;EACH,CAjBU;;EAkBXG,OAAO,EAAE;IACLT,WAAW,GAAE;MACT,KAAKU,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,IAAnC;MACAJ,OAAO,CAACC,GAAR,CAAY,UAAZ;MACA,KAAKE,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,KAAnC;IACJ;;EALK;AAlBE,CAAf","names":["axios","URLSearchParams","name","data","products","query","url","mounted","getProducts","post","window","location","search","substring","params","console","log","methods","$store","commit"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/Search.vue"],"sourcesContent":["<template>\n    <h1>HII</h1>\n</template>\n\n<script>\n    import axios from 'axios';\nimport { URLSearchParams } from 'url';\n    export default {\n        name: 'Search',\n        data() {\n            return {\n                products: [],                                \n                query: '',\n                url: 'http://127.0.0.1:8000/api/v1/products/search/?query='\n            }\n        },\n        mounted() {            \n            this.getProducts();\n            let post = window.location.search.substring(1)\n            let params = new URLSearchParams(post)\n            console.log(params)\n            if(params['query']){\n                this.query = params['query']\n            }\n        },\n        methods: {         \n            getProducts(){\n                this.$store.commit('setIsLoading', true)\n                console.log(\"Seaching\")               \n                this.$store.commit('setIsLoading', false)                \n            }            \n        }\n    };\n</script>"]},"metadata":{},"sourceType":"module"}