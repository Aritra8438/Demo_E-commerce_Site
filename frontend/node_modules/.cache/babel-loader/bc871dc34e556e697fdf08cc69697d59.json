{"ast":null,"code":"import axios from 'axios';\nimport { toast } from 'bulma-toast';\nexport default {\n  name: 'SignUp',\n\n  data() {\n    return {\n      emailId: \"\",\n      username: \"\",\n      password: \"\",\n      password2: \"\",\n      errors: []\n    };\n  },\n\n  methods: {\n    submitForm() {\n      this.errors = [];\n\n      if (this.username === '') {\n        this.errors.push('The username can not be empty');\n      }\n\n      if (this.password.length < 6) {\n        this.errors.push('The password is too short');\n      }\n\n      if (this.password !== this.password2) {\n        this.errors.push('The passwords doesn\\'t match');\n      }\n\n      if (this.errors.length === 0) {\n        const user = {\n          \"username\": this.username,\n          \"password\": this.password,\n          \"email\": this.emailId\n        };\n        axios.post(\"api/v1/users/\", user).then(response => {\n          toast({\n            message: 'Account created',\n            type: 'is-success',\n            dismissible: true,\n            pauseOnHover: true,\n            duration: 3000,\n            position: 'bottom-right'\n          });\n        });\n      }\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAuDA,OAAOA,KAAP,MAAkB,OAAlB;AACA,SAASC,KAAT,QAAsB,aAAtB;AACA,eAAe;EACXC,IAAI,EAAE,QADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,OAAO,EAAE,EADN;MAEHC,QAAQ,EAAE,EAFP;MAGHC,QAAQ,EAAE,EAHP;MAIHC,SAAS,EAAE,EAJR;MAKHC,MAAM,EAAE;IALL,CAAP;EAOH,CAVU;;EAWXC,OAAO,EAAE;IACLC,UAAU,GAAG;MACT,KAAKF,MAAL,GAAc,EAAd;;MACA,IAAI,KAAKH,QAAL,KAAkB,EAAtB,EAA0B;QACtB,KAAKG,MAAL,CAAYG,IAAZ,CAAiB,+BAAjB;MACJ;;MACA,IAAI,KAAKL,QAAL,CAAcM,MAAd,GAAuB,CAA3B,EAA8B;QAC1B,KAAKJ,MAAL,CAAYG,IAAZ,CAAiB,2BAAjB;MACJ;;MACA,IAAI,KAAKL,QAAL,KAAkB,KAAKC,SAA3B,EAAsC;QAClC,KAAKC,MAAL,CAAYG,IAAZ,CAAiB,8BAAjB;MACJ;;MACA,IAAI,KAAKH,MAAL,CAAYI,MAAZ,KAAuB,CAA3B,EAA8B;QAC1B,MAAMC,IAAG,GAAI;UACT,YAAY,KAAKR,QADR;UAET,YAAY,KAAKC,QAFR;UAGT,SAAS,KAAKF;QAHL,CAAb;QAKAJ,KAAI,CACCc,IADL,CACU,eADV,EAC2BD,IAD3B,EAEKE,IAFL,CAEUC,QAAO,IAAK;UACdf,KAAK,CAAC;YACFgB,OAAO,EAAE,iBADP;YAEFC,IAAI,EAAE,YAFJ;YAGFC,WAAW,EAAE,IAHX;YAIFC,YAAY,EAAE,IAJZ;YAKFC,QAAQ,EAAE,IALR;YAMFC,QAAQ,EAAE;UANR,CAAD,CAAL;QAQH,CAXL;MAYJ;IACJ;;EA/BK;AAXE,CAAf","names":["axios","toast","name","data","emailId","username","password","password2","errors","methods","submitForm","push","length","user","post","then","response","message","type","dismissible","pauseOnHover","duration","position"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/SignUp.vue"],"sourcesContent":["<template>\n    <div class=\"page-sign-up\">\n        <div class=\"columns\">\n            <div class=\"column is-4 is-offset-4\">\n                <h1 class=\"title\">Sign up</h1>\n\n                <form @submit.prevent=\"submitForm\">\n                    <div class=\"field\">\n                        <label>Username</label>\n                        <div class=\"control\">\n                            <input type=\"text\" class=\"input\" v-model=\"username\">\n                        </div>\n                    </div>\n\n                    <div class=\"field\">\n                        <label>Email Address</label>\n                        <div class=\"control\">\n                            <input type=\"email\" class=\"input\" v-model=\"emailId\">\n                        </div>\n                    </div>\n\n                    <div class=\"field\">\n                        <label>Password</label>\n                        <div class=\"control\">\n                            <input type=\"password\" class=\"input\" v-model=\"password\">\n                        </div>\n                    </div>\n\n                    <div class=\"field\">\n                        <label>Repeat password</label>\n                        <div class=\"control\">\n                            <input type=\"password\" class=\"input\" v-model=\"password2\">\n                        </div>\n                    </div>\n\n                    <div class=\"notification is-danger\" v-if=\"errors.length\">\n                        <p v-for=\"error in errors\" v-bind:key=\"error\">{{ error }}</p>\n                    </div>\n\n                    <div class=\"field\">\n                        <div class=\"control\">\n                            <button class=\"button is-dark\">Sign up</button>\n                        </div>\n                    </div>\n\n                    <hr>\n\n                    Or <router-link to=\"/login\">click here</router-link> to log in!\n                </form>\n            </div>\n        </div>\n    </div>\n</template>\n\n<script>\nimport axios from 'axios';\nimport { toast } from 'bulma-toast';\nexport default {\n    name: 'SignUp',\n    data() {\n        return {\n            emailId: \"\",\n            username: \"\",\n            password: \"\",\n            password2: \"\",\n            errors: [],\n        }\n    },\n    methods: {\n        submitForm() {\n            this.errors = []\n            if (this.username === '') {\n                this.errors.push('The username can not be empty')\n            }\n            if (this.password.length < 6) {\n                this.errors.push('The password is too short')\n            }\n            if (this.password !== this.password2) {\n                this.errors.push('The passwords doesn\\'t match')\n            }\n            if (this.errors.length === 0) {\n                const user = {\n                    \"username\": this.username,\n                    \"password\": this.password,\n                    \"email\": this.emailId,\n                }\n                axios\n                    .post(\"api/v1/users/\", user)\n                    .then(response => {\n                        toast({\n                            message: 'Account created',\n                            type: 'is-success',\n                            dismissible: true,\n                            pauseOnHover: true,\n                            duration: 3000,\n                            position: 'bottom-right',\n                        });\n                    })\n            }\n        }\n    },\n}\n</script>\n"]},"metadata":{},"sourceType":"module"}