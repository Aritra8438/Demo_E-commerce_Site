{"ast":null,"code":"import axios from 'axios';\nexport default {\n  data() {\n    return {\n      showMobileMenu: false,\n      search: \"\",\n      querySet: [],\n      dropdown: false,\n      url: \"/api/v1/auto?query=\",\n      cart: {\n        items: []\n      }\n    };\n  },\n\n  beforeCreate() {\n    this.$store.commit();\n  },\n\n  mounted() {},\n\n  updated() {},\n\n  methods: {\n    getJson() {\n      this.dropdown = true;\n      this.checkEmptySearch();\n      axios.get(this.url + this.search).then(response => {\n        console.log(response.data);\n        this.querySet = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n\n    toggleDropdown() {\n      this.dropdown = !this.dropdown;\n    },\n\n    checkEmptySearch() {\n      if (this.search == \"\") {\n        this.dropdown = false;\n      }\n    },\n\n    selectOption(string) {\n      this.search = string;\n      this.dropdown = false;\n    }\n\n  },\n  computed: {}\n};","map":{"version":3,"mappings":"AAgFA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACbC,IAAI,GAAG;IACL,OAAO;MACLC,cAAc,EAAE,KADX;MAELC,MAAM,EAAE,EAFH;MAGLC,QAAQ,EAAE,EAHL;MAILC,QAAQ,EAAE,KAJL;MAKLC,GAAG,EAAE,qBALA;MAMLC,IAAI,EAAE;QACJC,KAAK,EAAE;MADH;IAND,CAAP;EAUD,CAZY;;EAabC,YAAY,GAAG;IACb,KAAKC,MAAL,CAAYC,MAAZ;EACD,CAfY;;EAgBbC,OAAO,GAAG,CACT,CAjBY;;EAkBbC,OAAO,GAAG,CACT,CAnBY;;EAoBbC,OAAO,EAAE;IACPC,OAAO,GAAG;MACR,KAAKV,QAAL,GAAgB,IAAhB;MACA,KAAKW,gBAAL;MACAhB,KAAI,CACDiB,GADH,CACO,KAAKX,GAAL,GAAW,KAAKH,MADvB,EAEGe,IAFH,CAEQC,QAAO,IAAK;QAChBC,OAAO,CAACC,GAAR,CAAYF,QAAQ,CAAClB,IAArB;QACA,KAAKG,QAAL,GAAgBe,QAAQ,CAAClB,IAAzB;MACD,CALH,EAMGqB,KANH,CAMSC,KAAI,IAAK;QACdH,OAAO,CAACC,GAAR,CAAYE,KAAZ;MACD,CARH;IASD,CAbM;;IAcPC,cAAc,GAAG;MACf,KAAKnB,QAAL,GAAgB,CAAC,KAAKA,QAAtB;IACD,CAhBM;;IAiBPW,gBAAgB,GAAG;MACjB,IAAI,KAAKb,MAAL,IAAe,EAAnB,EAAuB;QACrB,KAAKE,QAAL,GAAgB,KAAhB;MACF;IACD,CArBM;;IAsBPoB,YAAY,CAACC,MAAD,EAAS;MACnB,KAAKvB,MAAL,GAAcuB,MAAd;MACA,KAAKrB,QAAL,GAAgB,KAAhB;IACF;;EAzBO,CApBI;EA+CbsB,QAAQ,EAAE;AA/CG,CAAf","names":["axios","data","showMobileMenu","search","querySet","dropdown","url","cart","items","beforeCreate","$store","commit","mounted","updated","methods","getJson","checkEmptySearch","get","then","response","console","log","catch","error","toggleDropdown","selectOption","string","computed"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/App.vue"],"sourcesContent":["<template>\n  <div id=\"wrapper\">\n    <nav class=\"navbar is-dark\">\n      <div class=\"navbar-brand\">\n        <router-link to=\"/\" class=\"navbar-item\"><strong>Bookish</strong></router-link>\n\n        <a class=\"navbar-burger\" aria-label=\"menu\" aria-expanded=\"false\" data-target=\"navbar-menu\"\n          @click=\"showMobileMenu = !showMobileMenu\">\n          <span aria-hidden=\"true\"></span>\n          <span aria-hidden=\"true\"></span>\n          <span aria-hidden=\"true\"></span>\n        </a>\n      </div>\n\n      <div class=\"navbar-menu\" id=\"navbar-menu\" v-bind:class=\"{ 'is-active': showMobileMenu }\">\n        <div class=\"navbar-start\">\n          <div class=\"navbar-item\">\n            <form method=\"get\" action=\"/search\">\n              <div class=\"field has-addons\">\n                <div class=\"dropdown\">\n                  <input type=\"text\" class=\"dropdown-input\" placeholder=\"What are you looking for?\" name=\"query\"\n                    v-model=\"search\" @input=\"getJson\" autocomplete=\"off\">\n                  <div class=\"dropdown-content\" v-show=\"dropdown\">\n                    <div class=\"dropdown-item\" v-for=\"(obj, index) in querySet\" :key=\"index\"\n                      @mousedown=\"selectOption(obj)\">\n                      {{ obj }}\n                    </div>\n                  </div>\n                </div>\n                <div class=\"control\">\n                  <button class=\"button is-success test\">\n                    <span class=\"icon\">\n                      <i class=\"fas fa-search\"></i>\n                    </span>\n                  </button>\n                </div>\n              </div>\n            </form>\n          </div>\n        </div>\n\n        <div class=\"navbar-end\">\n          <router-link to=\"/summer\" class=\"navbar-item\">Romance</router-link>\n          <router-link to=\"/winter\" class=\"navbar-item\">Thriller</router-link>\n\n          <div class=\"navbar-item\">\n            <div class=\"buttons\">\n              <template v-if=\"$store.state.isAuthenticated\">\n                <router-link to=\"/my-account\" class=\"button is-light\">My account</router-link>\n              </template>\n\n              <template v-else>\n                <router-link to=\"/log-in\" class=\"button is-light\">Log in</router-link>\n              </template>\n\n              <router-link to=\"/cart\" class=\"button is-success\">\n                <span class=\"icon\"><i class=\"fas fa-shopping-cart\"></i></span>\n                <span>Cart ({{ cartTotalLength }})</span>\n              </router-link>\n            </div>\n          </div>\n        </div>\n      </div>\n    </nav>\n\n    <div class=\"is-loading-bar has-text-centered\" v-bind:class=\"{ 'is-loading': $store.state.isLoading }\">\n      <div class=\"lds-dual-ring\"></div>\n    </div>\n\n    <section class=\"section\">\n      <router-view />\n    </section>\n\n    <footer class=\"footer\">\n      <p class=\"has-text-centered\">Copyright (c) 2021</p>\n    </footer>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios'\nexport default {\n  data() {\n    return {\n      showMobileMenu: false,\n      search: \"\",\n      querySet: [],\n      dropdown: false,\n      url: \"/api/v1/auto?query=\",\n      cart: {\n        items: [],\n      }\n    }\n  },\n  beforeCreate() {\n    this.$store.commit()\n  },\n  mounted() {\n  },\n  updated() {\n  },\n  methods: {\n    getJson() {\n      this.dropdown = true;\n      this.checkEmptySearch();\n      axios\n        .get(this.url + this.search)\n        .then(response => {\n          console.log(response.data)\n          this.querySet = response.data\n        })\n        .catch(error => {\n          console.log(error)\n        })\n    },\n    toggleDropdown() {\n      this.dropdown = !this.dropdown\n    },\n    checkEmptySearch() {\n      if (this.search == \"\") {\n        this.dropdown = false;\n      }\n    },\n    selectOption(string) {\n      this.search = string;\n      this.dropdown = false;\n    }\n  },\n  computed: {\n  }\n}\n</script>\n\n<style lang=\"scss\">\n@import '../node_modules/bulma';\n\n.lds-dual-ring {\n  display: inline-block;\n  width: 80px;\n  height: 80px;\n}\n\n.lds-dual-ring:after {\n  content: \" \";\n  display: block;\n  width: 64px;\n  height: 64px;\n  margin: 8px;\n  border-radius: 50%;\n  border: 6px solid #ccc;\n  border-color: #ccc transparent #ccc transparent;\n  animation: lds-dual-ring 1.2s linear infinite;\n}\n\n@keyframes lds-dual-ring {\n  0% {\n    transform: rotate(0deg);\n  }\n\n  100% {\n    transform: rotate(360deg);\n  }\n}\n\n.is-loading-bar {\n  height: 0;\n  overflow: hidden;\n  -webkit-transition: all 0.3s;\n  transition: all 0.3s;\n\n  &.is-loading {\n    height: 80px;\n  }\n}\n</style>\n<style lang=\"scss\" scoped>\n.test {\n  height: 30px;\n  width: 30px;\n}\n\n.dropdown {\n  position: relative;\n  display: block;\n  margin: auto;\n\n  .dropdown-input {\n    background: #fff;\n    cursor: pointer;\n    border: 1px solid #e7ecf5;\n    border-radius: 3px;\n    color: #333;\n    display: block;\n    font-size: .8em;\n    padding: 6px;\n    min-width: 250px;\n    max-width: 250px;\n\n    &:hover {\n      background: #f8f8fa;\n    }\n  }\n\n  .dropdown-content {\n    position: absolute;\n    background-color: #fff;\n    min-width: 248px;\n    max-width: 248px;\n    max-height: 248px;\n    border: 1px solid #e7ecf5;\n    box-shadow: 0px -8px 34px 0px rgba(0, 0, 0, 0.05);\n    overflow: auto;\n    z-index: 1;\n\n    .dropdown-item {\n      color: black;\n      font-size: .7em;\n      line-height: 1em;\n      padding: 8px;\n      text-decoration: none;\n      display: block;\n      cursor: pointer;\n\n      &:hover {\n        background-color: #e7ecf5;\n      }\n    }\n  }\n\n  .dropdown:hover .dropdowncontent {\n    display: block;\n  }\n}\n</style>"]},"metadata":{},"sourceType":"module"}