{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'Cart',\n\n  data() {\n    return {\n      cart: [],\n      items: []\n    };\n  },\n\n  mounted() {\n    this.cart = this.$store.state.cart;\n  },\n\n  computed: {\n    billingPrice() {\n      this.items = this.cart.items;\n      let total = 0;\n\n      for (let j in this.cart.items) {\n        total += this.cart.items[j].quantity * this.cart.items[j].product.price;\n      }\n\n      console.log(this.items);\n      return total;\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAqBI,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACXC,IAAI,EAAE,MADK;;EAEXC,IAAI,GAAG;IACH,OAAM;MACFC,IAAI,EAAE,EADJ;MAEFC,KAAK,EAAE;IAFL,CAAN;EAIH,CAPU;;EAQXC,OAAO,GAAG;IACN,KAAKF,IAAL,GAAY,KAAKG,MAAL,CAAYC,KAAZ,CAAkBJ,IAA9B;EACH,CAVU;;EAWXK,QAAQ,EAAE;IACNC,YAAY,GAAG;MACX,KAAKL,KAAL,GAAa,KAAKD,IAAL,CAAUC,KAAvB;MACA,IAAIM,KAAI,GAAI,CAAZ;;MACA,KAAI,IAAIC,CAAR,IAAa,KAAKR,IAAL,CAAUC,KAAvB,EAA6B;QACzBM,KAAI,IAAM,KAAKP,IAAL,CAAUC,KAAV,CAAgBO,CAAhB,EAAmBC,QAApB,GAA+B,KAAKT,IAAL,CAAUC,KAAV,CAAgBO,CAAhB,EAAmBE,OAAnB,CAA2BC,KAAnE;MACJ;;MACAC,OAAO,CAACC,GAAR,CAAY,KAAKZ,KAAjB;MACA,OAAOM,KAAP;IACJ;;EATM;AAXC,CAAf","names":["axios","name","data","cart","items","mounted","$store","state","computed","billingPrice","total","j","quantity","product","price","console","log"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/Cart.vue"],"sourcesContent":["<template>\n    <div>HII</div>\n    <div>{{billingPrice}}</div>\n    <div class=\"columns is-multiline\">\n        <section v-for=\"item in items\" :key=\"item.product.id\" class=\"column is-3 section is-small\">\n            <div class=\"box\">\n                <figure class=\"image mb-4\">\n                    <img :src=\"item.product.get_thumbnail\" alt=\"Oops\">\n                    <h6 class=\"is-size-5 has-text-weight-bold\">{{ item.product.name }}</h6>\n                    <p class=\"is-size-5 has-text-grey\">{{ item.quantity }} in cart</p>\n                    <p class=\"is-size-5 has-text-grey\">₹{{ item.product.price*item.quantity }}</p>\n                    <router-link v-bind:to=\"item.product.get_absolute_url\" class=\"button is-dark mt-4 center\">View\n                        details\n                    </router-link>\n                </figure>\n            </div>\n        </section>\n    </div>\n</template>\n\n<script>\n    import axios from 'axios';\n    export default {\n        name: 'Cart',\n        data() {\n            return{\n                cart: [],\n                items: [],\n            }            \n        },\n        mounted() {\n            this.cart = this.$store.state.cart                                    \n        },\n        computed: {\n            billingPrice() {\n                this.items = this.cart.items;\n                let total = 0;\n                for(let j in this.cart.items){                    \n                    total += (this.cart.items[j].quantity)*(this.cart.items[j].product.price);                    \n                }\n                console.log(this.items);\n                return total;\n            }\n        },        \n    }\n    \n</script>"]},"metadata":{},"sourceType":"module"}