{"ast":null,"code":"import axios from 'axios';\nimport { toast } from 'bulma-toast';\nexport default {\n  name: 'category',\n\n  data() {\n    return {\n      products: [],\n      url: \"/api/v1/products/\"\n    };\n  },\n\n  mounted() {\n    this.getProducts();\n  },\n\n  watch: {\n    $route(to, from) {\n      if (to.name === 'Category') {\n        this.getProducts();\n      }\n    }\n\n  },\n  methods: {\n    async getProducts() {\n      this.$store.commit('setIsLoading', true);\n      const category_slug = this.$route.params.category_slug;\n      const specific = this.url + category_slug;\n      console.log(specific);\n      await axios.get(specific).then(response => {\n        //console.log(response.data)\n        this.products = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAoBA,OAAOA,KAAP,MAAkB,OAAlB;AACA,SAASC,KAAT,QAAsB,aAAtB;AACA,eAAe;EACXC,IAAI,EAAE,UADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,QAAQ,EAAE,EADP;MAEHC,GAAG,EAAE;IAFF,CAAP;EAIH,CAPU;;EAQXC,OAAO,GAAG;IACN,KAAKC,WAAL;EACH,CAVU;;EAWXC,KAAK,EAAE;IACHC,MAAM,CAACC,EAAD,EAAKC,IAAL,EAAW;MACb,IAAID,EAAE,CAACR,IAAH,KAAY,UAAhB,EAA4B;QACxB,KAAKK,WAAL;MACJ;IACJ;;EALG,CAXI;EAkBXK,OAAO,EAAE;IACL,MAAML,WAAN,GAAoB;MAChB,KAAKM,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,IAAnC;MACA,MAAMC,aAAY,GAAI,KAAKN,MAAL,CAAYO,MAAZ,CAAmBD,aAAzC;MACA,MAAME,QAAO,GAAI,KAAKZ,GAAL,GAAWU,aAA5B;MACAG,OAAO,CAACC,GAAR,CAAYF,QAAZ;MACA,MAAMjB,KAAI,CACLoB,GADC,CACGH,QADH,EAEDI,IAFC,CAEIC,QAAO,IAAK;QACd;QACA,KAAKlB,QAAL,GAAgBkB,QAAQ,CAACnB,IAAzB;MACH,CALC,EAMDoB,KANC,CAMKC,KAAI,IAAK;QACZN,OAAO,CAACC,GAAR,CAAYK,KAAZ;MACH,CARC,CAAN;MASA,KAAKX,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,KAAnC;IAEJ;;EAjBK;AAlBE,CAAf","names":["axios","toast","name","data","products","url","mounted","getProducts","watch","$route","to","from","methods","$store","commit","category_slug","params","specific","console","log","get","then","response","catch","error"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/Category.vue"],"sourcesContent":["<template>\n    <div class=\"page-category\">\n        <div class=\"columns is-multiline\">\n            <section v-for=\"product in products\" :key=\"product.id\" class=\"column is-3 section is-small\">\n                <div class=\"box\">\n                    <figure class=\"image mb-4\">\n                        <img :src=\"product.get_thumbnail\" alt=\"Oops\">\n                        <h6 class=\"is-size-5 has-text-weight-bold\">{{ product.name }}</h6>\n                        <p class=\"is-size-5 has-text-grey\">₹{{ product.price }}</p>\n                        <router-link v-bind:to=\"product.get_absolute_url\" class=\"button is-dark mt-4 center\">View\n                            details\n                        </router-link>\n                    </figure>\n                </div>\n            </section>\n        </div>\n    </div>\n</template>\n\n<script>\nimport axios from 'axios';\nimport { toast } from 'bulma-toast';\nexport default {\n    name: 'category',\n    data() {\n        return {\n            products: [],\n            url: \"/api/v1/products/\",\n        }\n    },\n    mounted() {\n        this.getProducts()\n    },\n    watch: {\n        $route(to, from) {\n            if (to.name === 'Category') {\n                this.getProducts()\n            }\n        }\n    },\n    methods: {\n        async getProducts() {\n            this.$store.commit('setIsLoading', true)\n            const category_slug = this.$route.params.category_slug;\n            const specific = this.url + category_slug;\n            console.log(specific)\n            await axios\n                .get(specific)\n                .then(response => {\n                    //console.log(response.data)\n                    this.products = response.data;\n                })\n                .catch(error => {\n                    console.log(error)\n                })\n            this.$store.commit('setIsLoading', false)\n\n        }\n    }\n}\n</script>"]},"metadata":{},"sourceType":"module"}