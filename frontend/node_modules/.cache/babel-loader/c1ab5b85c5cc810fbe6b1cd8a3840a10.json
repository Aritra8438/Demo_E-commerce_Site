{"ast":null,"code":"import axios from 'axios';\nexport default {\n  data() {\n    return {\n      showMobileMenu: false,\n      search: \"\",\n      dropdown: true,\n      url: \"/api/v1/auto?query=\"\n    };\n  },\n\n  beforeCreate() {},\n\n  mounted() {},\n\n  updated() {\n    console.log(this.search);\n    this.getJson();\n  },\n\n  methods: {\n    getJson() {\n      axios.get(this.url + this.search).then(response => {\n        console.log(response.data);\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n\n    toggleDropdown() {\n      this.dropdown = !this.dropdown;\n    }\n\n  },\n  computed: {}\n};","map":{"version":3,"mappings":"AAiFA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACbC,IAAI,GAAG;IACL,OAAO;MACLC,cAAc,EAAE,KADX;MAELC,MAAM,EAAE,EAFH;MAGLC,QAAQ,EAAE,IAHL;MAILC,GAAG,EAAE;IAJA,CAAP;EAMD,CARY;;EASbC,YAAY,GAAG,CACd,CAVY;;EAWbC,OAAO,GAAG,CACT,CAZY;;EAabC,OAAO,GAAG;IACRC,OAAO,CAACC,GAAR,CAAY,KAAKP,MAAjB;IACA,KAAKQ,OAAL;EACD,CAhBY;;EAiBbC,OAAO,EAAE;IACPD,OAAO,GAAG;MACRX,KAAI,CACDa,GADH,CACO,KAAKR,GAAL,GAAW,KAAKF,MADvB,EAEGW,IAFH,CAEQC,QAAO,IAAK;QAChBN,OAAO,CAACC,GAAR,CAAYK,QAAQ,CAACd,IAArB;MACD,CAJH,EAKGe,KALH,CAKSC,KAAI,IAAK;QACdR,OAAO,CAACC,GAAR,CAAYO,KAAZ;MACD,CAPH;IAQD,CAVM;;IAWPC,cAAc,GAAG;MACf,KAAKd,QAAL,GAAgB,CAAC,KAAKA,QAAtB;IACF;;EAbO,CAjBI;EAgCbe,QAAQ,EAAE;AAhCG,CAAf","names":["axios","data","showMobileMenu","search","dropdown","url","beforeCreate","mounted","updated","console","log","getJson","methods","get","then","response","catch","error","toggleDropdown","computed"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/App.vue"],"sourcesContent":["<template>\n  <div id=\"wrapper\">\n    <nav class=\"navbar is-dark\">\n      <div class=\"navbar-brand\">\n        <router-link to=\"/\" class=\"navbar-item\"><strong>Bookish</strong></router-link>\n\n        <a class=\"navbar-burger\" aria-label=\"menu\" aria-expanded=\"false\" data-target=\"navbar-menu\"\n          @click=\"showMobileMenu = !showMobileMenu\">\n          <span aria-hidden=\"true\"></span>\n          <span aria-hidden=\"true\"></span>\n          <span aria-hidden=\"true\"></span>\n        </a>\n      </div>\n\n      <div class=\"navbar-menu\" id=\"navbar-menu\" v-bind:class=\"{ 'is-active': showMobileMenu }\">\n        <div class=\"navbar-start\">\n          <div class=\"navbar-item\">\n            <form method=\"get\" action=\"/search\">\n              <div class=\"field has-addons\">\n                <div class=\"dropdown\">\n                  <input type=\"text\" class=\"dropdown-input\" placeholder=\"What are you looking for?\" name=\"query\"\n                    v-model=\"search\" autocomplete=\"off\">\n                  <div class=\"dropdown-content\" v-show=\"dropdown\">\n                    <div class=\"dropdown-item\" @mousedown=\"\" v-for=\"(option, index) in filteredOptions\" :key=\"index\">\n                      {{ option.name || option.id || '-' }}\n                    </div>\n                  </div>\n\n                </div>\n\n                <div class=\"control\">\n                  <button class=\"button is-success\">\n                    <span class=\"icon\">\n                      <i class=\"fas fa-search\"></i>\n                    </span>\n                  </button>\n                </div>\n              </div>\n            </form>\n          </div>\n        </div>\n\n        <div class=\"navbar-end\">\n          <router-link to=\"/summer\" class=\"navbar-item\">Romance</router-link>\n          <router-link to=\"/winter\" class=\"navbar-item\">Thriller</router-link>\n\n          <div class=\"navbar-item\">\n            <div class=\"buttons\">\n              <template v-if=\"$store.state.isAuthenticated\">\n                <router-link to=\"/my-account\" class=\"button is-light\">My account</router-link>\n              </template>\n\n              <template v-else>\n                <router-link to=\"/log-in\" class=\"button is-light\">Log in</router-link>\n              </template>\n\n              <router-link to=\"/cart\" class=\"button is-success\">\n                <span class=\"icon\"><i class=\"fas fa-shopping-cart\"></i></span>\n                <span>Cart ({{ cartTotalLength }})</span>\n              </router-link>\n            </div>\n          </div>\n        </div>\n      </div>\n    </nav>\n\n    <div class=\"is-loading-bar has-text-centered\" v-bind:class=\"{ 'is-loading': $store.state.isLoading }\">\n      <div class=\"lds-dual-ring\"></div>\n    </div>\n\n    <section class=\"section\">\n      <router-view />\n    </section>\n\n    <footer class=\"footer\">\n      <p class=\"has-text-centered\">Copyright (c) 2021</p>\n    </footer>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios'\nexport default {\n  data() {\n    return {\n      showMobileMenu: false,\n      search: \"\",\n      dropdown: true,\n      url: \"/api/v1/auto?query=\",\n    }\n  },\n  beforeCreate() {\n  },\n  mounted() {\n  },\n  updated() {\n    console.log(this.search)\n    this.getJson()\n  },\n  methods: {\n    getJson() {\n      axios\n        .get(this.url + this.search)\n        .then(response => {\n          console.log(response.data)\n        })\n        .catch(error => {\n          console.log(error)\n        })\n    },\n    toggleDropdown() {\n      this.dropdown = !this.dropdown\n    }\n  },\n  computed: {\n  }\n}\n</script>\n\n<style lang=\"scss\">\n@import '../node_modules/bulma';\n\n.lds-dual-ring {\n  display: inline-block;\n  width: 80px;\n  height: 80px;\n}\n\n.lds-dual-ring:after {\n  content: \" \";\n  display: block;\n  width: 64px;\n  height: 64px;\n  margin: 8px;\n  border-radius: 50%;\n  border: 6px solid #ccc;\n  border-color: #ccc transparent #ccc transparent;\n  animation: lds-dual-ring 1.2s linear infinite;\n}\n\n@keyframes lds-dual-ring {\n  0% {\n    transform: rotate(0deg);\n  }\n\n  100% {\n    transform: rotate(360deg);\n  }\n}\n\n.is-loading-bar {\n  height: 0;\n  overflow: hidden;\n  -webkit-transition: all 0.3s;\n  transition: all 0.3s;\n\n  &.is-loading {\n    height: 80px;\n  }\n}\n</style>"]},"metadata":{},"sourceType":"module"}