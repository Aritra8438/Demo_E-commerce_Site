{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'HomeView',\n\n  data() {\n    return {\n      latestProducts: []\n    };\n  },\n\n  components: {},\n\n  mounted() {\n    console.log(\"Mounted\");\n    this.getLatestProducts();\n  },\n\n  methods: {\n    getLatestProducts() {\n      axios.get(\"/api/v1/latest-products/\").then(response => {\n        console.log(\"debug\");\n        console.log(response.data);\n        this.latestProducts = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAmCA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACbC,IAAI,EAAE,UADO;;EAEbC,IAAI,GAAG;IACL,OAAO;MACLC,cAAc,EAAE;IADX,CAAP;EAGD,CANY;;EAObC,UAAU,EAAE,EAPC;;EASbC,OAAO,GAAG;IACRC,OAAO,CAACC,GAAR,CAAY,SAAZ;IACA,KAAKC,iBAAL;EACD,CAZY;;EAabC,OAAO,EAAE;IACPD,iBAAiB,GAAG;MAClBR,KAAI,CACDU,GADH,CACO,0BADP,EAEGC,IAFH,CAEQC,QAAO,IAAK;QAChBN,OAAO,CAACC,GAAR,CAAY,OAAZ;QACAD,OAAO,CAACC,GAAR,CAAYK,QAAQ,CAACV,IAArB;QACA,KAAKC,cAAL,GAAsBS,QAAQ,CAACV,IAA/B;MACD,CANH,EAOGW,KAPH,CAOSC,KAAI,IAAK;QACdR,OAAO,CAACC,GAAR,CAAYO,KAAZ;MACD,CATH;IAUF;;EAZO;AAbI,CAAf","names":["axios","name","data","latestProducts","components","mounted","console","log","getLatestProducts","methods","get","then","response","catch","error"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/HomeView.vue"],"sourcesContent":["<template>\n  <div class=\"home\">\n    <section class=\"hero is-medium is-dark mb-6\">\n      <div class=\"hero-body has-text-centered\">\n        <p class=\"title mb-6\">\n          Welcome to Bookish\n        </p>\n        <p class=\"subtitle\">\n          A demo E-commerce website for shopping books\n        </p>\n      </div>\n    </section>\n\n    <div class=\"columns is-multiline\">\n      <div class=\"column is-12\">\n        <h2 class=\"is-size-2 has-text-centered\">Latest products</h2>\n      </div>\n    </div>\n\n    <div class=\"columns is-multiline\">\n      <section v-for=\"product in latestProducts\" :key=\"product.id\" class=\"column is-4 section is-medium\">\n        <div class=\"box\">\n          <figure class=\"image mb-4\">\n            <img :src=\"product.get_thumbnail\" alt=\"Oops\">\n            <h3 class=\"is-size-4\">{{ product.name }}</h3>\n            <p class=\"is-size-6 has-text-grey\">${{ product.price }}</p>\n          </figure>\n        </div>\n      </section>\n    </div>\n\n  </div>\n</template>\n\n<script>\nimport axios from 'axios';\nexport default {\n  name: 'HomeView',\n  data() {\n    return {\n      latestProducts: [],\n    }\n  },\n  components: {\n  },\n  mounted() {\n    console.log(\"Mounted\")\n    this.getLatestProducts()\n  },\n  methods: {\n    getLatestProducts() {\n      axios\n        .get(\"/api/v1/latest-products/\")\n        .then(response => {\n          console.log(\"debug\")\n          console.log(response.data)\n          this.latestProducts = response.data\n        })\n        .catch(error => {\n          console.log(error)\n        })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.image {\n  margin-top: -1.25rem;\n  margin-left: -1.25rem;\n  margin-right: -1.25rem;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}