{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'Search',\n\n  data() {\n    return {\n      products: [],\n      query: '',\n      url: 'http://127.0.0.1:8000/api/v1/products/search/'\n    };\n  },\n\n  mounted() {\n    let post = window.location.search.substring(1);\n    let params = new URLSearchParams(post);\n\n    if (params.get('query')) {\n      this.query = params.get('query');\n      this.performSearch();\n    }\n  },\n\n  methods: {\n    async performSearch() {\n      this.$store.commit('setIsLoading', true);\n      this.performAuto();\n      this.performElastic();\n      this.$store.commit('setIsLoading', false);\n    },\n\n    async performAuto() {\n      await axios.post(this.url, {\n        'query': this.query\n      }).then(response => {\n        this.products = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n\n    async performElastic() {\n      await axios.get(this.url, {\n        'query': this.query\n      }).then(response => {\n        this.products = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    }\n\n  }\n};","map":{"version":3,"mappings":"AA0BA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACXC,IAAI,EAAE,QADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,QAAQ,EAAE,EADP;MAEHC,KAAK,EAAE,EAFJ;MAGHC,GAAG,EAAE;IAHF,CAAP;EAKH,CARU;;EASXC,OAAO,GAAG;IACN,IAAIC,IAAG,GAAIC,MAAM,CAACC,QAAP,CAAgBC,MAAhB,CAAuBC,SAAvB,CAAiC,CAAjC,CAAX;IACA,IAAIC,MAAK,GAAI,IAAIC,eAAJ,CAAoBN,IAApB,CAAb;;IACA,IAAIK,MAAM,CAACE,GAAP,CAAW,OAAX,CAAJ,EAAyB;MACrB,KAAKV,KAAL,GAAaQ,MAAM,CAACE,GAAP,CAAW,OAAX,CAAb;MACA,KAAKC,aAAL;IACJ;EACH,CAhBU;;EAiBXC,OAAO,EAAE;IACL,MAAMD,aAAN,GAAsB;MAClB,KAAKE,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,IAAnC;MACA,KAAKC,WAAL;MACA,KAAKC,cAAL;MACA,KAAKH,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,KAAnC;IACH,CANI;;IAOL,MAAMC,WAAN,GAAoB;MAChB,MAAMnB,KAAI,CACLO,IADC,CACI,KAAKF,GADT,EACc;QAAE,SAAS,KAAKD;MAAhB,CADd,EAEDiB,IAFC,CAEIC,QAAO,IAAK;QACd,KAAKnB,QAAL,GAAgBmB,QAAQ,CAACpB,IAAzB;MACH,CAJC,EAKDqB,KALC,CAKKC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAR,CAAYF,KAAZ;MACH,CAPC,CAAN;IAQH,CAhBI;;IAiBL,MAAMJ,cAAN,GAAuB;MACnB,MAAMpB,KAAI,CACLc,GADC,CACG,KAAKT,GADR,EACa;QAAE,SAAS,KAAKD;MAAhB,CADb,EAEDiB,IAFC,CAEIC,QAAO,IAAK;QACd,KAAKnB,QAAL,GAAgBmB,QAAQ,CAACpB,IAAzB;MACH,CAJC,EAKDqB,KALC,CAKKC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAR,CAAYF,KAAZ;MACH,CAPC,CAAN;MAQA,KAAKP,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,KAAnC;IACJ;;EA3BK;AAjBE,CAAf","names":["axios","name","data","products","query","url","mounted","post","window","location","search","substring","params","URLSearchParams","get","performSearch","methods","$store","commit","performAuto","performElastic","then","response","catch","error","console","log"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/Search.vue"],"sourcesContent":["<template>\n    <div class=\"page-search\">\n        <div class=\"columns is-multiline\">\n            <div class=\"column is-12\">\n                <h1 class=\"title\">Search</h1>\n\n                <h2 class=\"is-size-5 has-text-grey\">Search term: \"{{ query }}\"</h2>\n            </div>\n            <section v-for=\"product in products\" :key=\"product.id\" class=\"column is-3 section is-small\">\n                <div class=\"box\">\n                    <figure class=\"image mb-4\">\n                        <img :src=\"product.get_thumbnail\" alt=\"Oops\">\n                        <h6 class=\"is-size-5 has-text-weight-bold\">{{ product.name }}</h6>\n                        <p class=\"is-size-5 has-text-grey\">₹{{ product.price }}</p>\n                        <router-link v-bind:to=\"product.get_absolute_url\" class=\"button is-dark mt-4 center\">View\n                            details\n                        </router-link>\n                    </figure>\n                </div>\n            </section>\n\n        </div>\n    </div>\n</template>\n\n<script>\nimport axios from 'axios';\nexport default {\n    name: 'Search',\n    data() {\n        return {\n            products: [],\n            query: '',\n            url: 'http://127.0.0.1:8000/api/v1/products/search/'\n        }\n    },\n    mounted() {\n        let post = window.location.search.substring(1)\n        let params = new URLSearchParams(post)\n        if (params.get('query')) {\n            this.query = params.get('query')\n            this.performSearch()\n        }\n    },\n    methods: {\n        async performSearch() {\n            this.$store.commit('setIsLoading', true);\n            this.performAuto();\n            this.performElastic();\n            this.$store.commit('setIsLoading', false);\n        },\n        async performAuto() {\n            await axios\n                .post(this.url, { 'query': this.query })\n                .then(response => {\n                    this.products = response.data\n                })\n                .catch(error => {\n                    console.log(error)\n                })\n        },\n        async performElastic() {\n            await axios\n                .get(this.url, { 'query': this.query })\n                .then(response => {\n                    this.products = response.data\n                })\n                .catch(error => {\n                    console.log(error)\n                })\n            this.$store.commit('setIsLoading', false)\n        }\n    }\n};\n</script>"]},"metadata":{},"sourceType":"module"}