{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'SignUp',\n\n  data() {\n    return {\n      username: \"\",\n      password: \"\",\n      password2: \"\",\n      errors: []\n    };\n  }\n\n};","map":{"version":3,"mappings":"AAgDA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACXC,IAAI,EAAE,QADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,QAAQ,EAAE,EADP;MAEHC,QAAQ,EAAE,EAFP;MAGHC,SAAS,EAAE,EAHR;MAIHC,MAAM,EAAE;IAJL,CAAP;EAMJ;;AATW,CAAf","names":["axios","name","data","username","password","password2","errors"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/SignUp.vue"],"sourcesContent":["<template>\n    <div class=\"page-sign-up\">\n        <div class=\"columns\">\n            <div class=\"column is-4 is-offset-4\">\n                <h1 class=\"title\">Sign up</h1>\n\n                <form @submit.prevent=\"submitForm\">\n                    <div class=\"field\">\n                        <label>Username</label>\n                        <div class=\"control\">\n                            <input type=\"text\" class=\"input\" v-model=\"username\">\n                        </div>\n                    </div>\n\n                    <div class=\"field\">\n                        <label>Password</label>\n                        <div class=\"control\">\n                            <input type=\"password\" class=\"input\" v-model=\"password\">\n                        </div>\n                    </div>\n\n                    <div class=\"field\">\n                        <label>Repeat password</label>\n                        <div class=\"control\">\n                            <input type=\"password\" class=\"input\" v-model=\"password2\">\n                        </div>\n                    </div>\n\n                    <div class=\"notification is-danger\" v-if=\"errors.length\">\n                        <p v-for=\"error in errors\" v-bind:key=\"error\">{{ error }}</p>\n                    </div>\n\n                    <div class=\"field\">\n                        <div class=\"control\">\n                            <button class=\"button is-dark\">Sign up</button>\n                        </div>\n                    </div>\n\n                    <hr>\n\n                    Or <router-link to=\"/signup\">click here</router-link> to log in!\n                </form>\n            </div>\n        </div>\n    </div>\n</template>\n\n<script>\nimport axios from 'axios';\nexport default {\n    name: 'SignUp',\n    data() {\n        return {\n            username: \"\",\n            password: \"\",\n            password2: \"\",\n            errors: [],\n        }\n    }\n}\n</script>\n"]},"metadata":{},"sourceType":"module"}