{"ast":null,"code":"import axios from 'axios';\nexport default {\n  data() {\n    return {\n      showMobileMenu: false,\n      search: \"\",\n      querySet: [],\n      dropdown: false,\n      url: \"/api/v1/auto?query=\",\n      cart: {\n        items: []\n      }\n    };\n  },\n\n  beforeCreate() {\n    this.$store.commit('initializeStore');\n    const token = this.$store.state.token;\n\n    if (token) {\n      axios.defaults.headers.common['Authorization'] = \"Token \" + token;\n    } else {\n      axios.defaults.headers.common['Authorization'] = \"\";\n    }\n  },\n\n  mounted() {\n    this.cart = this.$store.state.cart;\n  },\n\n  updated() {},\n\n  methods: {\n    getElastic() {\n      this.dropdown = true;\n      this.checkEmptySearch();\n      axios.get(\"/api/v1/search/inf/\").then(response => {\n        console.log(response.data);\n\n        for (let i = 0; i < response.data.length; i++) {\n          console.log(response.data[i]);\n          this.querySet.push(response.data[i].name);\n        }\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n\n    getJson() {\n      this.dropdown = true;\n      this.checkEmptySearch();\n      axios.get(this.url + this.search).then(response => {\n        this.querySet = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n\n    toggleDropdown() {\n      this.dropdown = !this.dropdown;\n    },\n\n    checkEmptySearch() {\n      if (this.search == \"\") {\n        this.dropdown = false;\n      }\n    },\n\n    selectOption(string) {\n      this.search = string;\n      this.dropdown = false;\n    },\n\n    goToProduct() {\n      console.log(this.search);\n    },\n\n    logOut() {\n      this.$store.commit('removeToken');\n    }\n\n  },\n  computed: {\n    cartTotalLength() {\n      let totalLength = 0;\n\n      for (let i = 0; i < this.cart.items.length; i++) {\n        totalLength += this.cart.items[i].quantity;\n      }\n\n      return totalLength;\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAmFA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACbC,IAAI,GAAG;IACL,OAAO;MACLC,cAAc,EAAE,KADX;MAELC,MAAM,EAAE,EAFH;MAGLC,QAAQ,EAAE,EAHL;MAILC,QAAQ,EAAE,KAJL;MAKLC,GAAG,EAAE,qBALA;MAMLC,IAAI,EAAE;QACJC,KAAK,EAAE;MADH;IAND,CAAP;EAUD,CAZY;;EAabC,YAAY,GAAG;IACb,KAAKC,MAAL,CAAYC,MAAZ,CAAmB,iBAAnB;IACA,MAAMC,KAAI,GAAI,KAAKF,MAAL,CAAYG,KAAZ,CAAkBD,KAAhC;;IACA,IAAIA,KAAJ,EAAW;MACTZ,KAAK,CAACc,QAAN,CAAeC,OAAf,CAAuBC,MAAvB,CAA8B,eAA9B,IAAiD,WAAWJ,KAA5D;IACF,CAFA,MAEO;MACLZ,KAAK,CAACc,QAAN,CAAeC,OAAf,CAAuBC,MAAvB,CAA8B,eAA9B,IAAiD,EAAjD;IACF;EACD,CArBY;;EAsBbC,OAAO,GAAG;IACR,KAAKV,IAAL,GAAY,KAAKG,MAAL,CAAYG,KAAZ,CAAkBN,IAA9B;EACD,CAxBY;;EAyBbW,OAAO,GAAG,CACT,CA1BY;;EA2BbC,OAAO,EAAE;IACPC,UAAU,GAAG;MACX,KAAKf,QAAL,GAAgB,IAAhB;MACA,KAAKgB,gBAAL;MACArB,KAAI,CACDsB,GADH,CACO,qBADP,EAEGC,IAFH,CAEQC,QAAO,IAAK;QAChBC,OAAO,CAACC,GAAR,CAAYF,QAAQ,CAACvB,IAArB;;QACA,KAAK,IAAI0B,IAAI,CAAb,EAAgBA,IAAIH,QAAQ,CAACvB,IAAT,CAAc2B,MAAlC,EAA0CD,CAAC,EAA3C,EAA+C;UAC7CF,OAAO,CAACC,GAAR,CAAYF,QAAQ,CAACvB,IAAT,CAAc0B,CAAd,CAAZ;UACA,KAAKvB,QAAL,CAAcyB,IAAd,CAAmBL,QAAQ,CAACvB,IAAT,CAAc0B,CAAd,EAAiBG,IAApC;QACF;MACD,CARH,EASGC,KATH,CASSC,KAAI,IAAK;QACdP,OAAO,CAACC,GAAR,CAAYM,KAAZ;MACD,CAXH;IAYD,CAhBM;;IAiBPC,OAAO,GAAG;MACR,KAAK5B,QAAL,GAAgB,IAAhB;MACA,KAAKgB,gBAAL;MACArB,KAAI,CACDsB,GADH,CACO,KAAKhB,GAAL,GAAW,KAAKH,MADvB,EAEGoB,IAFH,CAEQC,QAAO,IAAK;QAChB,KAAKpB,QAAL,GAAgBoB,QAAQ,CAACvB,IAAzB;MACD,CAJH,EAKG8B,KALH,CAKSC,KAAI,IAAK;QACdP,OAAO,CAACC,GAAR,CAAYM,KAAZ;MACD,CAPH;IAQD,CA5BM;;IA6BPE,cAAc,GAAG;MACf,KAAK7B,QAAL,GAAgB,CAAC,KAAKA,QAAtB;IACD,CA/BM;;IAgCPgB,gBAAgB,GAAG;MACjB,IAAI,KAAKlB,MAAL,IAAe,EAAnB,EAAuB;QACrB,KAAKE,QAAL,GAAgB,KAAhB;MACF;IACD,CApCM;;IAqCP8B,YAAY,CAACC,MAAD,EAAS;MACnB,KAAKjC,MAAL,GAAciC,MAAd;MACA,KAAK/B,QAAL,GAAgB,KAAhB;IACD,CAxCM;;IAyCPgC,WAAW,GAAG;MACZZ,OAAO,CAACC,GAAR,CAAY,KAAKvB,MAAjB;IACD,CA3CM;;IA4CPmC,MAAM,GAAG;MACP,KAAK5B,MAAL,CAAYC,MAAZ,CAAmB,aAAnB;IACF;;EA9CO,CA3BI;EA2Eb4B,QAAQ,EAAE;IACRC,eAAe,GAAG;MAChB,IAAIC,WAAU,GAAI,CAAlB;;MACA,KAAK,IAAId,IAAI,CAAb,EAAgBA,IAAI,KAAKpB,IAAL,CAAUC,KAAV,CAAgBoB,MAApC,EAA4CD,CAAC,EAA7C,EAAiD;QAC/Cc,WAAU,IAAK,KAAKlC,IAAL,CAAUC,KAAV,CAAgBmB,CAAhB,EAAmBe,QAAlC;MACF;;MACA,OAAOD,WAAP;IACF;;EAPQ;AA3EG,CAAf","names":["axios","data","showMobileMenu","search","querySet","dropdown","url","cart","items","beforeCreate","$store","commit","token","state","defaults","headers","common","mounted","updated","methods","getElastic","checkEmptySearch","get","then","response","console","log","i","length","push","name","catch","error","getJson","toggleDropdown","selectOption","string","goToProduct","logOut","computed","cartTotalLength","totalLength","quantity"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/App.vue"],"sourcesContent":["<template>\n  <div id=\"wrapper\">\n    <nav class=\"navbar is-dark\">\n      <div class=\"navbar-brand\">\n        <router-link to=\"/\" class=\"navbar-item\"><strong>Bookish</strong></router-link>\n\n        <a class=\"navbar-burger\" aria-label=\"menu\" aria-expanded=\"false\" data-target=\"navbar-menu\"\n          @click=\"showMobileMenu = !showMobileMenu\">\n          <span aria-hidden=\"true\"></span>\n          <span aria-hidden=\"true\"></span>\n          <span aria-hidden=\"true\"></span>\n        </a>\n      </div>\n\n      <div class=\"navbar-menu\" id=\"navbar-menu\" v-bind:class=\"{ 'is-active': showMobileMenu }\">\n        <div class=\"navbar-start\">\n          <div class=\"navbar-item\">\n            <form method=\"get\" action=\"/search\">\n              <div class=\"field has-addons\">\n                <div class=\"dropdown\">\n                  <input type=\"text\" class=\"dropdown-input\" placeholder=\"What are you looking for?\" name=\"query\"\n                    v-model=\"search\" @input=\"getJson() ; getElastic()\" autocomplete=\"off\">\n                  <div class=\"dropdown-content\" v-show=\"dropdown\">\n                    <div class=\"dropdown-item\" v-for=\"(obj, index) in querySet\" :key=\"index\"\n                      @mousedown=\"selectOption(obj)\">\n                      {{ obj }}\n                    </div>\n                  </div>\n                </div>\n                <div class=\"control\">\n                  <button class=\"button is-success test\" @click=\"goToProduct\">\n                    <span class=\"icon\">\n                      <i class=\"fas fa-search\"></i>\n                    </span>\n                  </button>\n                </div>\n              </div>\n            </form>\n          </div>\n        </div>\n\n        <div class=\"navbar-end\">\n          <router-link to=\"/romance\" class=\"navbar-item\">Romance</router-link>\n          <router-link to=\"/thriller\" class=\"navbar-item\">Thriller</router-link>\n\n          <div class=\"navbar-item\">\n            <div class=\"buttons\">\n              <template v-if=\"$store.state.isAuthenticated\">\n                <router-link to=\"/\" class=\"button is-light is-info\">My account</router-link>\n                <router-link to=\"/\" class=\"button is-light is-danger\" @click=\"logOut\">Log Out</router-link>\n              </template>\n\n              <template v-else>\n                <router-link to=\"/signup\" class=\"button is-light is-success\">Sign Up</router-link>\n                <router-link to=\"/login\" class=\"button is-light is-danger\">Log in</router-link>\n              </template>\n\n\n              <router-link to=\"/cart\" class=\"button is-success\">\n                <span class=\"icon\"><i class=\"fas fa-shopping-cart\"></i></span>\n                <span>Cart ({{ cartTotalLength }})</span>\n              </router-link>\n            </div>\n          </div>\n        </div>\n      </div>\n    </nav>\n\n    <div class=\"is-loading-bar has-text-centered\" v-bind:class=\"{ 'is-loading': $store.state.isLoading }\">\n      <div class=\"lds-dual-ring\"></div>\n    </div>\n\n    <section class=\"section\">\n      <router-view />\n    </section>\n\n    <footer class=\"footer\">\n      <p class=\"has-text-centered\">Copyright (c) 2021</p>\n    </footer>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios'\nexport default {\n  data() {\n    return {\n      showMobileMenu: false,\n      search: \"\",\n      querySet: [],\n      dropdown: false,\n      url: \"/api/v1/auto?query=\",\n      cart: {\n        items: [],\n      }\n    }\n  },\n  beforeCreate() {\n    this.$store.commit('initializeStore')\n    const token = this.$store.state.token\n    if (token) {\n      axios.defaults.headers.common['Authorization'] = \"Token \" + token\n    } else {\n      axios.defaults.headers.common['Authorization'] = \"\"\n    }\n  },\n  mounted() {\n    this.cart = this.$store.state.cart\n  },\n  updated() {\n  },\n  methods: {\n    getElastic() {\n      this.dropdown = true;\n      this.checkEmptySearch();\n      axios\n        .get(\"/api/v1/search/inf/\")\n        .then(response => {\n          console.log(response.data)\n          for (let i = 0; i < response.data.length; i++) {\n            console.log(response.data[i])\n            this.querySet.push(response.data[i].name)\n          }\n        })\n        .catch(error => {\n          console.log(error)\n        })\n    },\n    getJson() {\n      this.dropdown = true;\n      this.checkEmptySearch();\n      axios\n        .get(this.url + this.search)\n        .then(response => {\n          this.querySet = response.data\n        })\n        .catch(error => {\n          console.log(error)\n        })\n    },\n    toggleDropdown() {\n      this.dropdown = !this.dropdown\n    },\n    checkEmptySearch() {\n      if (this.search == \"\") {\n        this.dropdown = false;\n      }\n    },\n    selectOption(string) {\n      this.search = string;\n      this.dropdown = false;\n    },\n    goToProduct() {\n      console.log(this.search)\n    },\n    logOut() {\n      this.$store.commit('removeToken')\n    }\n  },\n  computed: {\n    cartTotalLength() {\n      let totalLength = 0;\n      for (let i = 0; i < this.cart.items.length; i++) {\n        totalLength += this.cart.items[i].quantity;\n      }\n      return totalLength;\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\">\n@import '../node_modules/bulma';\n\n.lds-dual-ring {\n  display: inline-block;\n  width: 80px;\n  height: 80px;\n}\n\n.lds-dual-ring:after {\n  content: \" \";\n  display: block;\n  width: 64px;\n  height: 64px;\n  margin: 8px;\n  border-radius: 50%;\n  border: 6px solid #ccc;\n  border-color: #ccc transparent #ccc transparent;\n  animation: lds-dual-ring 1.2s linear infinite;\n}\n\n@keyframes lds-dual-ring {\n  0% {\n    transform: rotate(0deg);\n  }\n\n  100% {\n    transform: rotate(360deg);\n  }\n}\n\n.is-loading-bar {\n  height: 0;\n  overflow: hidden;\n  -webkit-transition: all 0.3s;\n  transition: all 0.3s;\n\n  &.is-loading {\n    height: 80px;\n  }\n}\n</style>\n<style lang=\"scss\" scoped>\n.test {\n  height: 30px;\n  width: 30px;\n}\n\n.dropdown {\n  position: relative;\n  display: block;\n  margin: auto;\n\n  .dropdown-input {\n    background: #fff;\n    cursor: pointer;\n    border: 1px solid #e7ecf5;\n    border-radius: 3px;\n    color: #333;\n    display: block;\n    font-size: .8em;\n    padding: 6px;\n    min-width: 250px;\n    max-width: 250px;\n\n    &:hover {\n      background: #f8f8fa;\n    }\n  }\n\n  .dropdown-content {\n    position: absolute;\n    background-color: #fff;\n    min-width: 248px;\n    max-width: 248px;\n    max-height: 248px;\n    border: 1px solid #e7ecf5;\n    box-shadow: 0px -8px 34px 0px rgba(0, 0, 0, 0.05);\n    overflow: auto;\n    z-index: 1;\n\n    .dropdown-item {\n      color: black;\n      font-size: .7em;\n      line-height: 1em;\n      padding: 8px;\n      text-decoration: none;\n      display: block;\n      cursor: pointer;\n\n      &:hover {\n        background-color: #e7ecf5;\n      }\n    }\n  }\n\n  .dropdown:hover .dropdowncontent {\n    display: block;\n  }\n}\n</style>"]},"metadata":{},"sourceType":"module"}