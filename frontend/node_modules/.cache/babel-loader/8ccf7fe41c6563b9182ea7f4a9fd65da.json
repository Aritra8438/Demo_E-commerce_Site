{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'Product',\n\n  data() {\n    return {\n      product: {},\n      quantity: 1,\n      url: 'api/v1/products/'\n    };\n  },\n\n  mounted() {\n    this.getProduct();\n    console.log(\"HII\");\n    console.log(this.product);\n  },\n\n  methods: {\n    getProduct() {\n      const category_slug = this.$route.params.category_slug;\n      const product_slug = this.$route.params.product_slug;\n      const specific = category_slug + '/' + product_slug;\n      axios.get(url + specific).then(response => {\n        console.log(response.data);\n        this.product = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAiCA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACXC,IAAI,EAAE,SADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,OAAO,EAAE,EADN;MAEHC,QAAQ,EAAE,CAFP;MAGHC,GAAG,EAAE;IAHF,CAAP;EAMH,CATU;;EAUXC,OAAO,GAAG;IACN,KAAKC,UAAL;IACAC,OAAO,CAACC,GAAR,CAAY,KAAZ;IACAD,OAAO,CAACC,GAAR,CAAY,KAAKN,OAAjB;EACH,CAdU;;EAeXO,OAAO,EAAE;IACLH,UAAU,GAAG;MACT,MAAMI,aAAY,GAAI,KAAKC,MAAL,CAAYC,MAAZ,CAAmBF,aAAzC;MACA,MAAMG,YAAW,GAAI,KAAKF,MAAL,CAAYC,MAAZ,CAAmBC,YAAxC;MACA,MAAMC,QAAO,GAAIJ,aAAY,GAAI,GAAhB,GAAsBG,YAAvC;MACAd,KAAI,CACCgB,GADL,CACSX,GAAE,GAAIU,QADf,EAEKE,IAFL,CAEUC,QAAO,IAAK;QACdV,OAAO,CAACC,GAAR,CAAYS,QAAQ,CAAChB,IAArB;QACA,KAAKC,OAAL,GAAee,QAAQ,CAAChB,IAAxB;MACH,CALL,EAMKiB,KANL,CAMWC,KAAI,IAAK;QACZZ,OAAO,CAACC,GAAR,CAAYW,KAAZ;MACH,CARL;IASJ;;EAdK;AAfE,CAAf","names":["axios","name","data","product","quantity","url","mounted","getProduct","console","log","methods","category_slug","$route","params","product_slug","specific","get","then","response","catch","error"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/Product.vue"],"sourcesContent":["<template>\n    <div class=\"page-product\">\n        <div class=\"columns is-multiline\">\n            <div class=\"column is-9\">\n                <figure class=\"image mb-6\">\n                    <img v-bind:src=\"product.get_image\">\n                </figure>\n\n                <h1 class=\"title\">{{ product.name }}</h1>\n\n                <p>{{ product.description }}</p>\n            </div>\n\n            <div class=\"column is-3\">\n                <h2 class=\"subtitle\">Information</h2>\n\n                <p><strong>Price: </strong>₹{{ product.price }}</p>\n\n                <div class=\"field has-addons mt-6\">\n                    <div class=\"control\">\n                        <input type=\"number\" class=\"input\" min=\"1\" v-model=\"quantity\">\n                    </div>\n\n                    <div class=\"control\">\n                        <a class=\"button is-dark\">Add to cart</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</template>\n\n<script>\nimport axios from 'axios';\nexport default {\n    name: 'Product',\n    data() {\n        return {\n            product: {},\n            quantity: 1,\n            url: 'api/v1/products/'\n        }\n\n    },\n    mounted() {\n        this.getProduct();\n        console.log(\"HII\");\n        console.log(this.product);\n    },\n    methods: {\n        getProduct() {\n            const category_slug = this.$route.params.category_slug\n            const product_slug = this.$route.params.product_slug\n            const specific = category_slug + '/' + product_slug\n            axios\n                .get(url + specific)\n                .then(response => {\n                    console.log(response.data)\n                    this.product = response.data\n                })\n                .catch(error => {\n                    console.log(error)\n                })\n        }\n    }\n}\n\n</script>"]},"metadata":{},"sourceType":"module"}