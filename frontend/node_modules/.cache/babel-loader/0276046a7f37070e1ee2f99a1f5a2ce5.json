{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'Search',\n\n  data() {\n    return {\n      products: [],\n      query: '',\n      url: 'http://127.0.0.1:8000/api/v1/products/search/'\n    };\n  },\n\n  mounted() {\n    let post = window.location.search.substring(1);\n    let params = new URLSearchParams(post);\n    console.log(params.get('query'));\n    alert(\"HII\");\n\n    if (params.get('query')) {\n      this.query = params.get('query');\n      this.performSearch();\n    }\n  },\n\n  methods: {\n    async performSearch() {\n      this.$store.commit('setIsLoading', true);\n      await axios.post(this.url, {\n        'query': this.query\n      }).then(response => {\n        console.log(response.data);\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAKI,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACXC,IAAI,EAAE,QADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,QAAQ,EAAE,EADP;MAEHC,KAAK,EAAE,EAFJ;MAGHC,GAAG,EAAE;IAHF,CAAP;EAKH,CARU;;EASXC,OAAO,GAAG;IACN,IAAIC,IAAG,GAAIC,MAAM,CAACC,QAAP,CAAgBC,MAAhB,CAAuBC,SAAvB,CAAiC,CAAjC,CAAX;IACA,IAAIC,MAAK,GAAI,IAAIC,eAAJ,CAAoBN,IAApB,CAAb;IACAO,OAAO,CAACC,GAAR,CAAYH,MAAM,CAACI,GAAP,CAAW,OAAX,CAAZ;IACAC,KAAK,CAAC,KAAD,CAAL;;IACA,IAAGL,MAAM,CAACI,GAAP,CAAW,OAAX,CAAH,EAAuB;MACnB,KAAKZ,KAAL,GAAaQ,MAAM,CAACI,GAAP,CAAW,OAAX,CAAb;MACA,KAAKE,aAAL;IACJ;EACH,CAlBU;;EAmBXC,OAAO,EAAE;IACL,MAAMD,aAAN,GAAqB;MACjB,KAAKE,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,IAAnC;MACA,MAAMrB,KAAI,CACTO,IADK,CACA,KAAKF,GADL,EACS;QAAC,SAAQ,KAAKD;MAAd,CADT,EAELkB,IAFK,CAEAC,QAAQ,IAAE;QACZT,OAAO,CAACC,GAAR,CAAYQ,QAAQ,CAACrB,IAArB;MACH,CAJK,EAKLsB,KALK,CAKCC,KAAK,IAAE;QACVX,OAAO,CAACC,GAAR,CAAYU,KAAZ;MACH,CAPK,CAAN;MAQA,KAAKL,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,KAAnC;IACJ;;EAZK;AAnBE,CAAf","names":["axios","name","data","products","query","url","mounted","post","window","location","search","substring","params","URLSearchParams","console","log","get","alert","performSearch","methods","$store","commit","then","response","catch","error"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/Search.vue"],"sourcesContent":["<template>\n    <h1>HII</h1>\n</template>\n\n<script>\n    import axios from 'axios';\n    export default {\n        name: 'Search',\n        data() {\n            return {\n                products: [],                                \n                query: '',\n                url: 'http://127.0.0.1:8000/api/v1/products/search/'\n            }\n        },\n        mounted() {                        \n            let post = window.location.search.substring(1)\n            let params = new URLSearchParams(post)  \n            console.log(params.get('query'))\n            alert(\"HII\")          \n            if(params.get('query')){\n                this.query = params.get('query')\n                this.performSearch()\n            }\n        },\n        methods: {         \n            async performSearch(){\n                this.$store.commit('setIsLoading', true)                \n                await axios\n                .post(this.url,{'query':this.query})                 \n                .then(response=>{                    \n                    console.log(response.data)\n                })\n                .catch(error=>{\n                    console.log(error)\n                })                \n                this.$store.commit('setIsLoading', false)                \n            }            \n        }\n    };\n</script>"]},"metadata":{},"sourceType":"module"}