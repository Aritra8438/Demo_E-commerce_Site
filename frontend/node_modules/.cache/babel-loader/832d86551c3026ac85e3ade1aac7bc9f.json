{"ast":null,"code":"import axios from 'axios';\nexport default {\n  data() {\n    return {\n      showMobileMenu: false,\n      search: \"\",\n      querySet: [],\n      dropdown: false,\n      url: \"/api/v1/auto?query=\",\n      cart: {\n        items: []\n      }\n    };\n  },\n\n  beforeCreate() {\n    this.$store.commit('initializeStore');\n    const token = this.$store.state.token;\n\n    if (token) {\n      axios.defaults.headers.common['Authorization'] = \"Token \" + token;\n    } else {\n      axios.defaults.headers.common['Authorization'] = \"\";\n    }\n  },\n\n  mounted() {\n    this.cart = this.$store.state.cart;\n  },\n\n  updated() {},\n\n  methods: {\n    getSearch() {\n      this.dropdown = false;\n      this.checkEmptySearch();\n      if (this.search === '') return;\n      this.querySet = [];\n      this.getJson();\n      console.log(this.querySet.length + \" Before\");\n      this.getElastic();\n    },\n\n    getElastic() {\n      this.checkEmptySearch();\n      axios.get(\"/api/v1/search/\" + this.search + \"/\").then(response => {\n        for (let i = 0; i < response.data.length; i++) {\n          console.log(response.data[i].name);\n          this.querySet.push(response.data[i].name);\n        }\n\n        console.log(this.querySet.length);\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n\n    getJson() {\n      this.dropdown = true;\n      this.checkEmptySearch();\n      axios.get(this.url + this.search).then(response => {\n        for (let i = 0; i < response.data.length; i++) {\n          console.log(response.data[i] + \" H0\");\n          this.querySet.push(response.data[i] + \" Ho\");\n        }\n\n        console.log(this.querySet.length + \" Json\");\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n\n    toggleDropdown() {\n      this.dropdown = !this.dropdown;\n    },\n\n    checkEmptySearch() {\n      if (this.search == \"\") {\n        this.dropdown = false;\n      }\n    },\n\n    selectOption(string) {\n      this.search = string;\n      this.dropdown = false;\n    },\n\n    goToProduct() {\n      console.log(this.search);\n    },\n\n    logOut() {\n      this.$store.commit('removeToken');\n    }\n\n  },\n  computed: {\n    cartTotalLength() {\n      let totalLength = 0;\n\n      for (let i = 0; i < this.cart.items.length; i++) {\n        totalLength += this.cart.items[i].quantity;\n      }\n\n      return totalLength;\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAmFA,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACbC,IAAI,GAAG;IACL,OAAO;MACLC,cAAc,EAAE,KADX;MAELC,MAAM,EAAE,EAFH;MAGLC,QAAQ,EAAE,EAHL;MAILC,QAAQ,EAAE,KAJL;MAKLC,GAAG,EAAE,qBALA;MAMLC,IAAI,EAAE;QACJC,KAAK,EAAE;MADH;IAND,CAAP;EAUD,CAZY;;EAabC,YAAY,GAAG;IACb,KAAKC,MAAL,CAAYC,MAAZ,CAAmB,iBAAnB;IACA,MAAMC,KAAI,GAAI,KAAKF,MAAL,CAAYG,KAAZ,CAAkBD,KAAhC;;IACA,IAAIA,KAAJ,EAAW;MACTZ,KAAK,CAACc,QAAN,CAAeC,OAAf,CAAuBC,MAAvB,CAA8B,eAA9B,IAAiD,WAAWJ,KAA5D;IACF,CAFA,MAEO;MACLZ,KAAK,CAACc,QAAN,CAAeC,OAAf,CAAuBC,MAAvB,CAA8B,eAA9B,IAAiD,EAAjD;IACF;EACD,CArBY;;EAsBbC,OAAO,GAAG;IACR,KAAKV,IAAL,GAAY,KAAKG,MAAL,CAAYG,KAAZ,CAAkBN,IAA9B;EACD,CAxBY;;EAyBbW,OAAO,GAAG,CACT,CA1BY;;EA2BbC,OAAO,EAAE;IACPC,SAAS,GAAG;MACV,KAAKf,QAAL,GAAgB,KAAhB;MACA,KAAKgB,gBAAL;MACA,IAAI,KAAKlB,MAAL,KAAgB,EAApB,EAAwB;MACxB,KAAKC,QAAL,GAAgB,EAAhB;MACA,KAAKkB,OAAL;MACAC,OAAO,CAACC,GAAR,CAAY,KAAKpB,QAAL,CAAcqB,MAAd,GAAuB,SAAnC;MACA,KAAKC,UAAL;IACD,CATM;;IAUPA,UAAU,GAAG;MACX,KAAKL,gBAAL;MACArB,KAAI,CACD2B,GADH,CACO,oBAAoB,KAAKxB,MAAzB,GAAkC,GADzC,EAEGyB,IAFH,CAEQC,QAAO,IAAK;QAChB,KAAK,IAAIC,IAAI,CAAb,EAAgBA,IAAID,QAAQ,CAAC5B,IAAT,CAAcwB,MAAlC,EAA0CK,CAAC,EAA3C,EAA+C;UAC7CP,OAAO,CAACC,GAAR,CAAYK,QAAQ,CAAC5B,IAAT,CAAc6B,CAAd,EAAiBC,IAA7B;UACA,KAAK3B,QAAL,CAAc4B,IAAd,CAAmBH,QAAQ,CAAC5B,IAAT,CAAc6B,CAAd,EAAiBC,IAApC;QACF;;QACAR,OAAO,CAACC,GAAR,CAAY,KAAKpB,QAAL,CAAcqB,MAA1B;MACD,CARH,EASGQ,KATH,CASSC,KAAI,IAAK;QACdX,OAAO,CAACC,GAAR,CAAYU,KAAZ;MACD,CAXH;IAYD,CAxBM;;IAyBPZ,OAAO,GAAG;MACR,KAAKjB,QAAL,GAAgB,IAAhB;MACA,KAAKgB,gBAAL;MACArB,KAA