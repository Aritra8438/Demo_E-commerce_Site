{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'Search',\n\n  data() {\n    return {\n      products: [],\n      query: '',\n      url: 'http://127.0.0.1:8000/api/v1/products/search/'\n    };\n  },\n\n  mounted() {\n    this.getProducts();\n    let post = window.location.search.substring(1);\n    let params = new URLSearchParams(post);\n\n    if (params['query']) {\n      this.query = params['query'];\n      this.performSearch;\n    }\n  },\n\n  methods: {\n    async getProducts() {\n      this.$store.commit('setIsLoading', true);\n      await axios.post();\n      this.$store.commit('setIsLoading', false);\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAKI,OAAOA,KAAP,MAAkB,OAAlB;AACA,eAAe;EACXC,IAAI,EAAE,QADK;;EAEXC,IAAI,GAAG;IACH,OAAO;MACHC,QAAQ,EAAE,EADP;MAEHC,KAAK,EAAE,EAFJ;MAGHC,GAAG,EAAE;IAHF,CAAP;EAKH,CARU;;EASXC,OAAO,GAAG;IACN,KAAKC,WAAL;IACA,IAAIC,IAAG,GAAIC,MAAM,CAACC,QAAP,CAAgBC,MAAhB,CAAuBC,SAAvB,CAAiC,CAAjC,CAAX;IACA,IAAIC,MAAK,GAAI,IAAIC,eAAJ,CAAoBN,IAApB,CAAb;;IACA,IAAGK,MAAM,CAAC,OAAD,CAAT,EAAmB;MACf,KAAKT,KAAL,GAAaS,MAAM,CAAC,OAAD,CAAnB;MACA,KAAKE,aAAL;IACJ;EACH,CAjBU;;EAkBXC,OAAO,EAAE;IACL,MAAMT,WAAN,GAAmB;MACf,KAAKU,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,IAAnC;MACA,MAAMlB,KAAI,CACTQ,IADK,EAAN;MAEA,KAAKS,MAAL,CAAYC,MAAZ,CAAmB,cAAnB,EAAmC,KAAnC;IACJ;;EANK;AAlBE,CAAf","names":["axios","name","data","products","query","url","mounted","getProducts","post","window","location","search","substring","params","URLSearchParams","performSearch","methods","$store","commit"],"sourceRoot":"","sources":["/home/ARITRA/Documents/Vue_Django/Bookish/frontend/src/views/Search.vue"],"sourcesContent":["<template>\n    <h1>HII</h1>\n</template>\n\n<script>\n    import axios from 'axios';\n    export default {\n        name: 'Search',\n        data() {\n            return {\n                products: [],                                \n                query: '',\n                url: 'http://127.0.0.1:8000/api/v1/products/search/'\n            }\n        },\n        mounted() {            \n            this.getProducts();\n            let post = window.location.search.substring(1)\n            let params = new URLSearchParams(post)            \n            if(params['query']){\n                this.query = params['query']\n                this.performSearch\n            }\n        },\n        methods: {         \n            async getProducts(){\n                this.$store.commit('setIsLoading', true)\n                await axios\n                .post()                 \n                this.$store.commit('setIsLoading', false)                \n            }            \n        }\n    };\n</script>"]},"metadata":{},"sourceType":"module"}